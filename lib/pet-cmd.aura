; lib/pet-cmd.aura — slash command system for aura-pets.
;
; Primary interface: type /cmd [args] then Enter.
; Also accepts bare cmd without slash for short names.
;
; Returns (keep? . pet) same as game-do.
; Fight uses player coords via (cmd-set-pos! x y) before dispatch.

(define *cmd-px* 0)
(define *cmd-py* 0)

(define (cmd-set-pos! x y)
  (set! *cmd-px* x)
  (set! *cmd-py* y)
  #t)

; Lowercase ASCII letters in place (leave non-letters).
(define (cmd-downcase-ascii s)
  (let ((n (string-length s)))
    (let loop ((i 0) (acc (substring "x" 0 0)))
      (if (>= i n)
          acc
        (let* ((ch (substring s i (+ i 1)))
               (c (char->integer (car (string->list ch))))
               (out (if (and (>= c 65) (<= c 90))
                        (list->string (list (integer->char (+ c 32))))
                      ch)))
          (loop (+ i 1) (string-append acc out)))))))

; Strip leading spaces and one leading '/'.
(define (cmd-normalize raw)
  (let ((n (string-length raw)))
    (let loop ((i 0))
      (if (and (< i n) (string=? (substring raw i (+ i 1)) " "))
          (loop (+ i 1))
        (if (and (< i n) (string=? (substring raw i (+ i 1)) "/"))
            (substring raw (+ i 1) n)
          (if (>= i n)
              (substring "x" 0 0)
            (substring raw i n)))))))

; Split first token and rest: "grow tiger" → ("grow" . "tiger")
(define (cmd-split s)
  (let ((n (string-length s)))
    (let loop ((i 0))
      (if (>= i n)
          (cons s (substring "x" 0 0))
        (if (string=? (substring s i (+ i 1)) " ")
            (cons (substring s 0 i)
                  (let skip ((j i))
                    (if (and (< j n) (string=? (substring s j (+ j 1)) " "))
                        (skip (+ j 1))
                      (substring s j n))))
          (loop (+ i 1)))))))

(define (cmd-help-text)
  (try (tut-help-short)
       (catch (e)
         "/tutorial · /brain /mutate /diff · /save /npc /grow · /help")))

; Soft try-mode only (optional walkthrough). Never blocks free play.
(define (cmd-tut-after! act . rest)
  (try
    (let ((prefix (if (and (pair? rest) (string? (car rest)))
                      (car rest)
                    "")))
      (if (> (string-length prefix) 0)
          (tut-react-act-blend! act prefix)
        (tut-react-act! act)))
    (catch (e) #f)))

; Core slash dispatcher. pet is the live pet record.
(define (cmd-run pet raw)
  (let* ((norm (cmd-normalize raw))
         (parts (cmd-split norm))
         (head (cmd-downcase-ascii (car parts)))
         (args (cdr parts)))
    (cond
      ; ── meta ──
      ; /help — short command index; points to full interactive guide
      ((or (string=? head "help") (string=? head "h") (string=? head "?"))
       (if (= (string-length args) 0)
           (begin
             (set! *speech* (cmd-help-text))
             (set! *last-act* "help")
             (cons #t pet))
         ; /help care → same as /tutorial care
         (begin
           (set! *speech*
             (try (tut-dispatch! args) (catch (e) (cmd-help-text))))
           (set! *last-act* "help")
           (cons #t pet))))

      ; /tutorial [topic|n|next|back|try|close] — interactive play guide
      ((or (string=? head "tutorial") (string=? head "tut")
           (string=? head "lesson") (string=? head "guide-me")
           (string=? head "howto") (string=? head "manual"))
       (set! *speech*
         (try (tut-dispatch! args)
              (catch (e) "Guide: /tutorial · /tut care|code|fight · /n next")))
       (set! *last-act* "tutorial")
       (cons #t pet))

      ; /n /next /more — next guide page (auto-opens menu if closed)
      ; Note: /back is morph-prev; use /b or /tutorial back for guide prev.
      ((or (string=? head "n") (string=? head "next") (string=? head "more"))
       (set! *speech*
         (try
           (begin
             (if (not (tut-open?))
                 (tut-show-page! 0)
               #t)
             (tut-next!))
           (catch (e) "Type /tutorial first")))
       (set! *last-act* "tutorial")
       (cons #t pet))

      ; /b only — guide previous (do NOT steal /back from morph)
      ((string=? head "b")
       (set! *speech*
         (try
           (begin
             (if (not (tut-open?))
                 (tut-show-page! 0)
               #t)
             (tut-back!))
           (catch (e) "Type /tutorial back")))
       (set! *last-act* "tutorial")
       (cons #t pet))

      ; /skip|/close — close guide / stop try-mode
      ((or (string=? head "skip") (string=? head "skiptut")
           (string=? head "notut") (string=? head "close"))
       (set! *speech*
         (try (tut-close!) (catch (e) "Guide closed. /tutorial anytime")))
       (set! *last-act* "skip")
       (cons #t pet))

      ((or (string=? head "quit") (string=? head "q") (string=? head "bye")
           (string=? head "exit"))
       (set! *speech* "Bye-bye! Come back soon!")
       (set! *last-act* "bye")
       (cons #f pet))

      ((or (string=? head "status") (string=? head "stats") (string=? head "info"))
       (set! *speech*
         (string-append
           (combat-status pet)
           " love" (game-love-stars)
           " E" (number->string (pet-energy pet))))
       (set! *last-act* "status")
       (cons #t pet))

      ((or (string=? head "form") (string=? head "morph"))
       (set! *speech*
         (string-append "Form: " (pet-form-name (pet-version pet))
                        " v" (number->string (pet-version pet))))
       (set! *last-act* "form")
       (cons #t pet))

      ((or (string=? head "brain") (string=? head "edsl")
           (string=? head "genome") (string=? head "code"))
       (set! *speech*
         (try (genome-brain-show) (catch (e) (edsl-show))))
       (set! *last-act* "brain")
       ; Tutorial: advance to /mutate (short next prompt; brain was set above)
       (cmd-tut-after! "brain")
       (cons #t pet))

      ((or (string=? head "diff") (string=? head "evo")
           (string=? head "log") (string=? head "evolutions"))
       (set! *speech*
         (try (string-append (genome-diff-show) " | " (genome-log-show))
              (catch (e) "diff: n/a")))
       (set! *last-act* "diff")
       (cmd-tut-after! "diff" "Code changed!")
       (cons #t pet))

      ((or (string=? head "mutate") (string=? head "evolve-code")
           (string=? head "rewrite"))
       (set! *speech*
         (try (genome-force-mutate!) (catch (e) "mutate failed")))
       (set! *last-act* "mutate")
       (anim-start! "evolve" 12)
       ; Short fixed prefix — full toast is often >48 chars
       (cmd-tut-after! "mutate" "Source rewrote!")
       (cons #t pet))

      ; /guide lazy | /guide more fierce | free: "be more clingy"
      ((or (string=? head "guide") (string=? head "shape")
           (string=? head "temper"))
       (if (= (string-length args) 0)
           (begin
             (set! *speech* "Usage: /guide lazy|fierce|clingy|curious|quiet")
             (set! *last-act* "guide")
             (cons #t pet))
         (let ((toast (try (genome-guide! args) (catch (e) #f))))
           (if toast
               (begin
                 (set! *speech* toast)
                 (set! *last-act* "evolve-code")
                 (anim-start! "evolve" 12)
                 (cons #t pet))
             (begin
               (set! *speech* "Try: lazy fierce clingy curious quiet chatty calm")
               (set! *last-act* "guide")
               (cons #t pet))))))

      ; /npc [Name|@near|kind=enemy] [set hp 20|trait fierce +2|diff|brain]
      ((or (string=? head "npc") (string=? head "entity")
           (string=? head "mob") (string=? head "unit"))
       (try (ent-set-near! *cmd-px* *cmd-py*) (catch (e) #f))
       (let ((toast
               (try (entity-slash-npc! args)
                    (catch (e) "NPC edit failed"))))
         (set! *speech* toast)
         (set! *last-act* "npc-mutate")
         (anim-start! "evolve" 8)
         (cons #t pet)))

      ; /save [path] — life progress (genome + edsl + NPCs)
      ((or (string=? head "save") (string=? head "sav"))
       (set! *speech*
         (try
           (begin
             (if (= (string-length args) 0)
                 (pet-save-default!)
               (pet-save! args))
             (save-last-toast))
           (catch (e) "Save failed")))
       (set! *last-act* "save")
       (cmd-tut-after! "save" "Life saved!")
       (cons #t pet))

      ; /load [path] — restore mind (play-safe data AST)
      ((or (string=? head "load") (string=? head "continue")
           (string=? head "restore"))
       (set! *speech*
         (try
           (begin
             (if (= (string-length args) 0)
                 (pet-load-default!)
               (pet-load! args))
             (save-last-toast))
           (catch (e) "Load failed")))
       (set! *last-act* "load")
       (try (tut-off!) (catch (e) #f))
       (cons #t pet))

      ; /new — new life (soft reset); tip points at interactive guide
      ((or (string=? head "new") (string=? head "newgame")
           (string=? head "reset-life"))
       (try (pet-new-life!) (catch (e) #f))
       (try (tut-off!) (catch (e) #f))
       (set! *speech*
         (try
           (string-append (save-last-toast) " · /tutorial for guide")
           (catch (e) "New life! · /tutorial for guide")))
       (set! *last-act* "new")
       (anim-start! "evolve" 10)
       (cons #t pet))

      ; /export [path] — share/debug export (not the primary progress slot)
      ((or (string=? head "export") (string=? head "save-brain")
           (string=? head "dump"))
       (set! *speech*
         (try
           (begin
             (if (= (string-length args) 0)
                 (pet-export! (save-empty))
               (pet-export! args))
             (save-last-toast))
           (catch (e)
             (try
               (begin
                 (entity-export-session! "/tmp/aura-pets-session.aura")
                 "Exported /tmp/aura-pets-session.aura")
               (catch (e2) "Export failed")))))
       (set! *last-act* "export")
       (cons #t pet))

      ; ── care ──
      ((or (string=? head "eat") (string=? head "feed") (string=? head "1")
           (string=? head "f") (string=? head "nom"))
       (let ((r (game-apply-care pet "feed" pet-feed "eat")))
         (cmd-tut-after! "feed")
         r))

      ((or (string=? head "play") (string=? head "2") (string=? head "p"))
       (game-apply-care pet "play" pet-play "play"))

      ((or (string=? head "sleep") (string=? head "zzz") (string=? head "3")
           (string=? head "s") (string=? head "z") (string=? head "rest"))
       (game-apply-care pet "sleep" pet-sleep "sleep"))

      ; ── morph ──
      ((or (string=? head "grow") (string=? head "evolve") (string=? head "e")
           (string=? head "up") (string=? head "level"))
       (let ((r (pet-grow pet "slash-grow")))
         (if (car r)
             (let ((u (cdr r)))
               (combat-sync-form! u)
               (set! *last-act* "grow")
               (set! *speech*
                 (string-append "Grew into " (pet-form-name (pet-version u)) "!") )
               (anim-start! "evolve" 16)
               (cons #t u))
           (begin
             (set! *speech* "Max form! Try /back")
             (set! *last-act* "grow")
             (cons #t pet)))))

      ((or (string=? head "back") (string=? head "down") (string=? head "undo")
           (string=? head "prev"))
       (let ((r (pet-morph-back pet)))
         (if (car r)
             (let ((u (cdr r)))
               (combat-sync-form! u)
               (set! *last-act* "back")
               (set! *speech*
                 (string-append "Back to " (pet-form-name (pet-version u))))
               (anim-start! "play" 10)
               (cons #t u))
           (begin
             (set! *speech* "No previous form.")
             (set! *last-act* "back")
             (cons #t pet)))))

      ; ── combat ──
      ((or (string=? head "fight") (string=? head "atk") (string=? head "attack")
           (string=? head "hit") (string=? head "battle") (string=? head "punch")
           (string=? head "fire") (string=? head "shoot") (string=? head "shot"))
       ; Prefer ranged shot; melee if no facing fire
       (if (battle-pet-fire! pet *cmd-px* *cmd-py*)
           (begin
             (set! *speech*
               (string-append "Pew! [" (battle-weapon) "]"))
             (set! *last-act* "fire")
             (cons #t pet))
         (let ((r (combat-fight! pet *cmd-px* *cmd-py*)))
           (set! *speech* (car r))
           (set! *last-act* "fight")
           (cons #t (cdr r)))))

      ((or (string=? head "weapon") (string=? head "wpn") (string=? head "gun"))
       (if (= (string-length args) 0)
           (begin
             (set! *speech*
               (string-append "Weapon: " (battle-cycle-weapon! (pet-version pet))
                              " (shot/double/beam/bomb/fire)"))
             (set! *last-act* "weapon")
             (cons #t pet))
         (if (battle-set-weapon! (cmd-downcase-ascii args) (pet-version pet))
             (begin
               (set! *speech* (string-append "Weapon -> " (battle-weapon)))
               (set! *last-act* "weapon")
               (cons #t pet))
           (begin
             (set! *speech* "Need higher form for that weapon!")
             (cons #t pet)))))

      ((or (string=? head "heal") (string=? head "potion") (string=? head "recover"))
       (let ((r (combat-heal-pair! pet)))
         (set! *speech* (car r))
         (set! *last-act* "heal")
         (cons #t (cdr r))))

      ; ── social / world ──
      ((or (string=? head "talk") (string=? head "t") (string=? head "chat"))
       (set! *last-act* "talk")
       (set! *speech* "talk") ; caller replaces with nearest speech
       (cons #t pet))

      ((or (string=? head "world") (string=? head "gen") (string=? head "g")
           (string=? head "scene"))
       (set! *last-act* "world")
       (set! *speech* "world")
       (cons #t pet))

      ; ── background style / recipe (instant; LLM can also emit layers:) ──
      ; /bg                  → recipe summary
      ; /bg cyber            → preset + palette
      ; /bg layers rain,16|petals,2
      ; /bg accent 255,100,160
      ; /bg rain 18
      ((or (string=? head "bg") (string=? head "background")
           (string=? head "backdrop") (string=? head "scene"))
       (if (= (string-length args) 0)
           (begin
             (set! *speech*
               (try (world-recipe-summary)
                    (catch (e)
                      (string-append "bg=" (world-bg-style)
                                     " try: cyber stars ocean | layers …"))))
             (set! *last-act* "bg")
             (cons #t pet))
         (let* ((parts (cmd-split args))
                (sub (cmd-downcase-ascii (car parts)))
                (rest (cdr parts)))
           (cond
             ; /bg layers rain,12|dots,3|stars
             ((or (string=? sub "layers") (string=? sub "layer")
                  (string=? sub "recipe"))
              (try (world-set-layers-str! rest) (catch (e) #f))
              (set! *speech*
                (try (world-recipe-summary)
                     (catch (e) "layers set")))
              (set! *last-act* "bg")
              (cons #t pet))
             ; /bg accent 255,100,160
             ((or (string=? sub "accent") (string=? sub "tint"))
              (try (world-set-accent! (parse-rgb rest)) (catch (e) #f))
              (set! *speech*
                (string-append "accent set · " (try (world-recipe-summary)
                                                    (catch (e) "ok"))))
              (set! *last-act* "bg")
              (cons #t pet))
             ; /bg rain 18
             ((string=? sub "rain")
              (try (world-set-rain-n! (world-num-or rest 12)) (catch (e) #f))
              (set! *speech*
                (string-append "rain=" (number->string
                                         (try *bg-rain-n* (catch (e) 12)))))
              (set! *last-act* "bg")
              (cons #t pet))
             ; presets
             ((or (string=? sub "cyber") (string=? sub "matrix")
                  (string=? sub "neon"))
              (world-apply-cyber-palette!)
              (set! *speech*
                (string-append "Cyber rain ON! · "
                               (try (world-recipe-summary) (catch (e) ""))))
              (set! *last-act* "bg")
              (cons #t pet))
             (else
              (world-set-bg-style! sub)
              (cond
                ((string=? (world-bg-style) "stars")
                 (world-set-sky! (world-rgb 4 6 24))
                 (world-set-sky2! (world-rgb 12 10 40))
                 (world-set-floor! (world-rgb 18 20 40))
                 (world-set-floor2! (world-rgb 10 12 28))
                 (world-set-star! (world-rgb 230 235 255))
                 (world-set-accent! (world-rgb 230 235 255)))
                ((string=? (world-bg-style) "ocean")
                 (world-set-sky! (world-rgb 80 160 230))
                 (world-set-sky2! (world-rgb 180 220 255))
                 (world-set-floor! (world-rgb 200 180 120))
                 (world-set-floor2! (world-rgb 170 150 100))
                 (world-set-accent! (world-rgb 40 120 200)))
                ((string=? (world-bg-style) "city")
                 (world-set-sky! (world-rgb 20 25 50))
                 (world-set-sky2! (world-rgb 60 40 70))
                 (world-set-floor! (world-rgb 30 30 40))
                 (world-set-floor2! (world-rgb 20 20 28))
                 (world-set-accent! (world-rgb 255 220 80)))
                ((string=? (world-bg-style) "sunset")
                 (world-set-sky! (world-rgb 40 30 90))
                 (world-set-sky2! (world-rgb 90 50 70))
                 (world-set-floor! (world-rgb 55 110 65))
                 (world-set-floor2! (world-rgb 40 90 50))
                 (world-set-star! (world-rgb 255 220 160))
                 (world-set-accent! (world-rgb 255 160 120)))
                ((string=? (world-bg-style) "grid")
                 (world-set-sky! (world-rgb 5 12 22))
                 (world-set-sky2! (world-rgb 3 8 16))
                 (world-set-floor! (world-rgb 0 40 55))
                 (world-set-floor2! (world-rgb 0 20 30))
                 (world-set-accent! (world-rgb 0 200 180)))
                (else
                 (world-set-sky! (world-rgb 30 50 90))
                 (world-set-sky2! (world-rgb 45 70 110))
                 (world-set-floor! (world-rgb 55 110 65))
                 (world-set-floor2! (world-rgb 40 90 50))
                 (world-set-accent! (world-rgb 255 120 160))))
              (set! *speech*
                (try (world-recipe-summary)
                     (catch (e)
                       (string-append "Background -> " (world-bg-style)))))
              (set! *last-act* "bg")
              (cons #t pet))))))

      ; ── teach: /teach feed Hello ──
      ((string=? head "teach")
       (if (game-try-teach! (string-append "teach " args))
           (cons #t pet)
         (begin
           (set! *speech* "Usage: /teach feed Hi!")
           (cons #t pet))))

      ((string=? head "say")
       (if (= (string-length args) 0)
           (begin (set! *speech* "Usage: /say hello") (cons #t pet))
         (begin
           (set! *speech* args)
           (set! *last-act* "say")
           (cons #t pet))))

      ; unknown slash — soft hint
      (else
       (set! *speech* (string-append "Unknown /" head " — try /help"))
       (set! *last-act* "idle")
       (cons #t pet)))))

; True if string is a slash command (starts with / after trim).
(define (cmd-is-slash? raw)
  (let ((n (string-length raw)))
    (let loop ((i 0))
      (if (>= i n)
          #f
        (if (string=? (substring raw i (+ i 1)) " ")
            (loop (+ i 1))
          (string=? (substring raw i (+ i 1)) "/"))))))

; True if bare word is a known primary command (no slash required).
(define (cmd-is-bare? raw)
  (let* ((norm (cmd-normalize raw))
         (parts (cmd-split norm))
         (head (cmd-downcase-ascii (car parts))))
    (or (string=? head "eat") (string=? head "feed") (string=? head "play")
        (string=? head "sleep") (string=? head "1") (string=? head "2")
        (string=? head "3") (string=? head "grow") (string=? head "evolve")
        (string=? head "back") (string=? head "fight") (string=? head "heal")
        (string=? head "status") (string=? head "stats") (string=? head "form")
        (string=? head "help") (string=? head "talk") (string=? head "world")
        (string=? head "bg") (string=? head "background")
        (string=? head "brain") (string=? head "quit") (string=? head "say")
        (string=? head "teach") (string=? head "atk") (string=? head "attack")
        (string=? head "fire") (string=? head "shoot") (string=? head "weapon")
        (string=? head "wpn") (string=? head "gun")
        (string=? head "diff") (string=? head "mutate") (string=? head "guide")
        (string=? head "genome") (string=? head "code") (string=? head "evo")
        (string=? head "rewrite") (string=? head "temper")
        (string=? head "npc") (string=? head "entity") (string=? head "mob")
        (string=? head "export") (string=? head "save-brain")
        (string=? head "dump") (string=? head "save") (string=? head "load")
        (string=? head "new") (string=? head "continue")
        (string=? head "restore")
        (string=? head "tutorial") (string=? head "tut")
        (string=? head "lesson") (string=? head "howto")
        (string=? head "manual") (string=? head "guide-me")
        (string=? head "skip") (string=? head "skiptut")
        (string=? head "notut") (string=? head "close")
        (string=? head "n") (string=? head "next") (string=? head "more")
        (string=? head "b"))))

; lib/pet-edsl.aura — pet behavior eDSL (business AST-as-data).
;
; The "brain" is a list of rules:
;   (event speech love-delta)
; event: "feed" | "play" | "sleep" | "evolve" | "idle" | "move"
;
; Online change (kids / parents):
;   (edsl-teach! "feed" "Nom!")     ; rewrites the rule in place
;   (edsl-show)                     ; printable source of truth
;
; Aura killer path (engine mutation) — see docs/DESIGN.md §eDSL:
;   snapshot → mutate:set-body / set-code + typecheck → eval-current
;   or swap-binding! on behavior-path (atomic-swap).
; This file keeps a pure data eDSL so play works without loading mutate
; mid-session; edsl-aura-commit! is the optional live-mutation bridge.

(define *edsl-rules*
  (list
    (list "feed" "Yum yum! So good!" 1)
    (list "play" "Wheee! That was fun!" 1)
    (list "sleep" "Zzz... feeling cozy." 1)
    (list "evolve" "Sparkle!! New look!" 1)
    (list "move" "Boing!" 0)
    (list "idle" "..." 0)))

(define (edsl-reset!)
  (set! *edsl-rules*
    (list
      (list "feed" "Yum yum! So good!" 1)
      (list "play" "Wheee! That was fun!" 1)
      (list "sleep" "Zzz... feeling cozy." 1)
      (list "evolve" "Sparkle!! New look!" 1)
      (list "move" "Boing!" 0)
      (list "idle" "..." 0)))
  #t)

(define (edsl-rules) *edsl-rules*)

(define (edsl-find event)
  (let loop ((xs *edsl-rules*))
    (if (null? xs)
        #f
      (if (string=? (car (car xs)) event)
          (car xs)
        (loop (cdr xs))))))

(define (edsl-speech event)
  (let ((r (edsl-find event)))
    (if r (car (cdr r)) "...")))

(define (edsl-love-delta event)
  (let ((r (edsl-find event)))
    (if r (car (cdr (cdr r))) 0)))

; Rewrite or append a rule — this IS the in-process AST mutation of the eDSL.
(define (edsl-teach! event speech)
  (let ((love (edsl-love-delta event)))
    (let loop ((xs *edsl-rules*) (acc '()))
      (cond
        ((null? xs)
         (set! *edsl-rules*
           (append (reverse acc) (list (list event speech love))))
         #t)
        ((string=? (car (car xs)) event)
         (set! *edsl-rules*
           (append (reverse acc)
                   (cons (list event speech love) (cdr xs))))
         #t)
        (else (loop (cdr xs) (cons (car xs) acc)))))))

; Human-readable eDSL dump (ASCII, safe for tui:cell/draw-text).
(define (edsl-show)
  (let loop ((xs *edsl-rules*) (s "brain:"))
    (if (null? xs)
        s
      (let ((r (car xs)))
        (loop (cdr xs)
              (string-append s " [" (car r) "->" (car (cdr r)) "]"))))))

; Serialize rules as Aura source for set-code / mutate pipelines.
(define (edsl-to-aura-source)
  (let loop ((xs *edsl-rules*) (s "(define *edsl-rules* (list"))
    (if (null? xs)
        (string-append s "))\n")
      (let ((r (car xs)))
        (loop (cdr xs)
              (string-append s
                " (list \"" (car r) "\" \"" (car (cdr r)) "\" "
                (number->string (car (cdr (cdr r)))) ")"))))))

; Hot path (play-safe):
;   1. (edsl-teach!) already rewrote *edsl-rules* in-process (AST-as-data).
;   2. (ast:snapshot) records a named version point in Aura's AST store.
;   3. Side-file /tmp/aura-pets-edsl.aura holds the new define for tooling.
; We deliberately do NOT call set-code / eval-current mid-session: replacing
; the workspace flat invalidates closures from loaded modules (TUI breaks).
; Returns "snap" | "local".
; Play-safe: write small side file only. Skip ast:snapshot mid-session
; (observed SIGSEGV in eval_flat after long play + LLM apply).
(define (edsl-aura-commit!)
  (let ((src (edsl-to-aura-source)))
    (try
      (begin
        (try (write-file "/tmp/aura-pets-edsl.aura" src) (catch (e) #f))
        "save")
      (catch (e) "local"))))

; examples/cat-demo.aura — R2.2: move + anim + debug log
;
; Keys (empty prompt): arrows move, 1/2/3 care, e grow, q bye
; Debug log: /tmp/aura-pets-debug.log (or AURA_PETS_LOG)
;
; Load order (run.sh): lifecycle edsl anim game pet-log pixel this prompt(last)

(require "std/tui/sprite" all:)
(require "std/tui/canvas" all:)

; Canvas size — filled by (layout-fit!) from (tui:terminal-size).
; Defaults used until fit; play/demo call layout-fit! before tui:init.
(define W 80)
(define H 24)
; Truecolor HUD as packed 24-bit ints (r<<16|g<<8|b).
; Do NOT call (rgb ...) at top-level after require — Aura can leave empty bindings.
(define TITLE-CYAN 5302015)      ; 80 230 255
(define HUD-DIM 9216190)         ; 140 160 190
(define BAR-FG 5957240)          ; 90 230 120
(define BAR-LO 16747590)         ; 255 140 70
(define IN-FG 16120575)          ; 245 250 255
(define SPEECH-FG 16770650)      ; 255 230 90
(define SPEECH-BUBBLE 16755410)  ; 255 170 210
(define BG 526866)               ; 8 10 18
(define MATRIX-GREEN 6615190)    ; 100 240 150
(define NEON-PINK 16742590)      ; 255 120 190
; Layout: HUD 0-2 | room | speech SCENE-Y1 | Grok-style 3-row input box PROMPT-Y..+2
(define SCENE-Y0 3)
(define SCENE-Y1 18)
(define PROMPT-Y 20)
; Compact refined cat (~7×4 half-block cells; was 12×6)
(define CAT-W 7)
(define CAT-H 4)

; Clamp n into [lo, hi]
(define (clamp-n n lo hi)
  (if (< n lo) lo (if (> n hi) hi n)))

; Read TTY size (rows . cols) and rebuild layout to fill the window.
; Prefer full terminal; only clamp absurd sizes (min 40x16, max 220x80).
; Fallback: COLUMNS/LINES env when ioctl returns 0 (some pipes/ssh).
(define (layout-env-num name)
  (try
    (let ((s (getenv name)))
      (if (string? s) (string->number s) 0))
    (catch (e) 0)))

(define (layout-fit!)
  (let* ((sz (tui:terminal-size))
         (rows (car sz))
         (cols (cdr sz))
         (env-c (layout-env-num "COLUMNS"))
         (env-r (layout-env-num "LINES"))
         (raw-w (if (> cols 0) cols
                  (if (and (number? env-c) (> env-c 0)) env-c W)))
         (raw-h (if (> rows 0) rows
                  (if (and (number? env-r) (> env-r 0)) env-r H)))
         (w (clamp-n raw-w 40 220))
         (h (clamp-n raw-h 16 80)))
    (set! W w)
    (set! H h)
    (set! SCENE-Y0 3)
    ; leave 1 speech + 3-row bordered prompt box at bottom
    (set! SCENE-Y1 (clamp-n (- h 5) 8 (- h 4)))
    (set! PROMPT-Y (clamp-n (- h 3) 5 (- h 1)))
    ; full-width Grok-style box
    (try (prompt-set-width! (clamp-n w 40 220)) (catch (e) #f))
    #t))
(define BAR0 "..........")
(define BAR1 "=.........")
(define BAR2 "==........")
(define BAR3 "===.......")
(define BAR4 "====......")
(define BAR5 "=====.....")
(define BAR6 "======....")
(define BAR7 "=======...")
(define BAR8 "========..")
(define BAR9 "=========.")
(define BAR10 "==========")

(define (bar n)
  (cond
    ((<= n 0) BAR0)
    ((= n 1) BAR1)
    ((= n 2) BAR2)
    ((= n 3) BAR3)
    ((= n 4) BAR4)
    ((= n 5) BAR5)
    ((= n 6) BAR6)
    ((= n 7) BAR7)
    ((= n 8) BAR8)
    ((= n 9) BAR9)
    (else BAR10)))

(define (clamp-x x)
  (if (< x 1) 1
    (if (> x (- W CAT-W 1)) (- W CAT-W 1) x)))

(define (clamp-y y)
  (if (< y SCENE-Y0) SCENE-Y0
    (if (> y (- SCENE-Y1 CAT-H)) (- SCENE-Y1 CAT-H) y)))

(define (draw-hud! pet frame-n)
  (draw-text 1 0 "Mochi" TITLE-CYAN BG)
  (draw-text 7 0
             (string-append (pet-form-name (pet-version pet))
                            " " (battle-weapon)
                            " " (battle-face)
                            " love" (game-love-stars))
             MATRIX-GREEN BG)
  ; Pretty HP bar
  (draw-hp-bar! 1 1 (combat-hp) (combat-max) 12 "HP")
  ; Vitals mini
  (draw-text 20 1 "F" BAR-FG BG)
  (draw-text 21 1 (bar (pet-hunger pet)) BAR-FG BG)
  (draw-text 32 1 "H" BAR-FG BG)
  (draw-text 33 1 (bar (pet-mood pet))
             (if (< (pet-mood pet) 5) BAR-LO BAR-FG) BG)
  (draw-text 44 1 "E" BAR-FG BG)
  (draw-text 45 1 (bar (pet-energy pet)) BAR-FG BG)
  (draw-text 1 2
             (string-append
               (let ((th (try (tut-hud) (catch (e) ""))))
                 (if (and (string? th) (> (string-length th) 0))
                     (string-append th " | ")
                   ""))
               "Space fire | /bg cyber | ["
               (world-theme) " bg="
               (world-bg-style) " n="
               (number->string (world-npc-count))
               (if (nl-busy?) " ...]" "]"))
             HUD-DIM BG)
  #t)

(define (pose-face pose blink mood)
  (cond
    ((string=? pose "eat") "O_O")
    ((string=? pose "play") "^o^")
    ((string=? pose "sleep") "-_-")
    ((string=? pose "evolve") "*_*")
    (else (if blink "-.-"
            (if (string=? mood "happy") "^_^"
              (if (string=? mood "ok") "o.o" "u.u"))))))

(define (draw-speech! pet cat-x cat-y frame-n)
  (let ((pose (anim-kind))
        ; Slow blink (~4s at 25fps, natural cat rate). 2 frames long
        ; so the lid closes & opens. Idle only.
        (blink (and (string=? (anim-kind) "idle")
                    (or (= (modulo frame-n 100) 99)
                        (= (modulo frame-n 100) 0)))))
    (draw-text cat-x (+ cat-y CAT-H)
               (string-append "(" (pose-face pose blink (game-mood-kid pet)) ")")
               SPEECH-BUBBLE BG)
    (draw-text 1 SCENE-Y1
               (string-append "\" " (game-speech) " \"")
               SPEECH-FG BG)
    #t))

(define (draw-scene! pet frame-n cat-x cat-y)
  (let* ((pose (anim-kind))
         (phase (anim-phase))
         (draw-y (+ cat-y (anim-hop)))
         (blink (and (string=? pose "idle") (= (modulo frame-n 6) 5))))
    ; Sky via C++ clear (fast); world-draw-bg only paints floor + sparse FX.
    (tui:clear (bg-base-sky) (bg-base-sky))
    (world-draw-bg! W H SCENE-Y0 SCENE-Y1 frame-n)
    (world-draw-npcs! frame-n)
    (battle-draw-npc-hud! frame-n)
    (draw-hud! pet frame-n)
    (draw-pixel-cat! cat-x draw-y blink (game-mood-kid pet)
                     (pet-version pet) pose phase (battle-face))
    (battle-draw-overlay!)
    (draw-speech! pet cat-x cat-y frame-n)
    ; log dim cyan on box fill; input bright; cursor black-on-white
    (prompt-draw! 11189196 IN-FG BG 0 16777215)
    (tui:present)
    #t))

; Slash/bare commands + world/talk + free-text NL director.
; LLM jobs are async: start background Python, keep moving; poll in play-step!.
(define (apply-cmd-world pet cmd)
  (cmd-set-pos! *p-x* *p-y*)
  (cond
    ; ── slash or known bare command (/grow /eat /fight …) ──
    ((or (cmd-is-slash? cmd) (cmd-is-bare? cmd))
     (let ((r (cmd-run pet cmd)))
       (let ((act (game-last-act))
             (u (cmd-pet r pet)))
         ; Post-hooks for talk / world (need live coords / async)
         (cond
           ((string=? act "talk")
            (let ((s (world-nearest-speech *p-x* *p-y*)))
              (if s
                  (begin (game-set-speech! s) (prompt-set-log! s) (plog "talk" s))
                (begin
                  (game-set-speech! "No one nearby. Walk closer!")
                  (prompt-set-log! (game-speech))))
              (cons #t u)))
           ((string=? act "world")
            (if (nl-busy?)
                (begin
                  (game-set-speech! "Still thinking... walk around!")
                  (prompt-set-log! (game-speech))
                  (cons #t u))
              (begin
                (prompt-set-log! "Building world... (async)")
                (plog "world" "generate-async-start")
                (nl-start-worldgen-async! W H)
                (game-set-speech! (nl-last-say))
                (prompt-set-log! (game-speech))
                (cons #t u))))
           (else
            (prompt-set-log! (game-speech))
            (plog "cmd" (string-append "in=" cmd " act=" act))
            r)))))
    ((or (string=? cmd "world") (string=? cmd "gen") (string=? cmd "g"))
     (if (nl-busy?)
         (begin
           (game-set-speech! "Still thinking... walk around!")
           (prompt-set-log! (game-speech))
           (cons #t pet))
       (begin
         (prompt-set-log! "Building world... (async)")
         (plog "world" "generate-async-start")
         (nl-start-worldgen-async! W H)
         (game-set-speech! (nl-last-say))
         (prompt-set-log! (game-speech))
         (cons #t pet))))
    ((or (string=? cmd "talk") (string=? cmd "t"))
     (let ((s (world-nearest-speech *p-x* *p-y*)))
       (if s
           (begin
             (game-set-speech! s)
             (prompt-set-log! s)
             (plog "talk" s)
             (cons #t pet))
         (begin
           (game-set-speech! "No one nearby. Walk closer!")
           (prompt-set-log! (game-speech))
           (cons #t pet)))))
    ; Slice A: free-text personality guide before LLM director
    ((try (genome-looks-like-guide? cmd) (catch (e) #f))
     (let ((toast (try (genome-guide! cmd) (catch (e) #f))))
       (if toast
           (begin
             (game-set-speech! toast)
             (prompt-set-log! toast)
             (anim-start! "evolve" 12)
             (plog "genome" "guide")
             (cons #t pet))
         (begin
           (game-set-speech! "Guide: lazy fierce clingy curious quiet chatty")
           (prompt-set-log! (game-speech))
           (cons #t pet)))))
    ; Offline NPC intent (query→mutate) before LLM
    ((try (entity-offline-intent cmd) (catch (e) #f))
     (try (ent-set-near! *p-x* *p-y*) (catch (e) #f))
     (let ((ops (try (entity-offline-intent cmd) (catch (e) #f))))
       (if ops
           (let ((toast (try (intent-run! ops) (catch (e) #f))))
             (if toast
                 (begin
                   (game-set-speech! toast)
                   (prompt-set-log! toast)
                   (anim-start! "evolve" 8)
                   (plog "entity" "offline-intent")
                   (cons #t pet))
               (cons #t pet)))
         (cons #t pet))))
    ; Free language → async LLM director (non-blocking)
    ((nl-should-handle? cmd)
     (if (nl-busy?)
         (begin
           (game-set-speech! "Still thinking... arrows still work!")
           (prompt-set-log! (game-speech))
           (plog "nl" "busy-reject")
           (cons #t pet))
       (begin
         (plog "nl" (string-append "async-in=" cmd))
         (nl-start-async! cmd W H)
         (game-set-speech! (nl-last-say))
         (prompt-set-log! (game-speech))
         (cons #t pet))))
    (else (apply-cmd pet cmd))))

(define (apply-cmd pet cmd)
  (let ((r (game-do pet cmd)))
    (prompt-set-log! (game-speech))
    r))

(define (still-going? r)
  (if (not (pair? r))
      #t
    (if (eq? (car r) #f) #f #t)))

(define (cmd-pet r pet-fallback)
  (if (pair? r) (cdr r) pet-fallback))

(define (move-by cat-x cat-y dx dy)
  (game-on-move!)
  (cons (clamp-x (+ cat-x dx)) (clamp-y (+ cat-y dy))))

; Fluid move: up to *nav-budget* steps per frame so key-repeat feels snappy
; when several arrow events land in one drain. Extra events only re-aim.
; Double-tap same arrow within *dash-window* frames → 2-cell dash.
(define *nav-budget* 0)
(define *nav-max-per-frame* 4)
(define *dash-window* 18)

(define (nav-apply! dir dx dy)
  (battle-set-face! dir)
  (if (<= *nav-budget* 0)
      #t
    (let* ((same (and (string=? dir *dash-dir*)
                      (> *dash-frame* 0)
                      (< (- *p-frame* *dash-frame*) *dash-window*)
                      (> (- *p-frame* *dash-frame*) 0)))
           (step (if same 2 1))
           (xy (move-by *p-x* *p-y* (* dx step) (* dy step))))
      (set! *nav-budget* (- *nav-budget* 1))
      (set! *dash-dir* dir)
      (set! *dash-frame* *p-frame*)
      (set! *p-x* (car xy))
      (set! *p-y* (cdr xy))
      (if same
          (begin
            (game-set-speech! "Dash!")
            (anim-start! "play" 4))
        #t)
      ; Tutorial beat 1: first real move advances (dash still counts as move)
      (try
        (let ((msg (tut-on-act! "move")))
          (if msg
              (prompt-set-log! msg)
            #f))
        (catch (e) #f))
      #t)))

; Input first, non-blocking drain, short wait only after empty queue.
(define (play-drain-input!)
  (set! *nav-budget* *nav-max-per-frame*)
  ; Drain pending keys (no sleep) — catch up after a heavy draw frame.
  (let loop ((n 0))
    (if (>= n 24)
        #t
      (let ((e (tui:read-event 0)))
        (if e
            (begin (play-handle-event! e) (loop (+ n 1)))
          #t))))
  ; Short block so idle is not a hot spin (~2ms; was 8ms and felt laggy).
  (play-handle-event! (tui:read-event 2)))

; Demo frame state (host while — no named-let recursion).
(define *d-i* 0)
(define *d-n* 0)
(define *d-pet* #f)
(define *d-x* 8)
(define *d-y* 5)

(define (cat-demo-anim n)
  (layout-fit!)
  ; #t = full cell buffer (needed for box-drawing / UTF-8 frame-ansi)
  (tui:init "aura-pets" W H #t)
  (tui:hide-cursor)
  (prompt-init! PROMPT-Y)
  (prompt-set-width! W)
  (game-reset!)
  (morph-reset!)
  ; Demo: load prebuilt world file, else offline defaults (no live API).
  (world-set-path! "/tmp/aura-pets-world.txt")
  (if (file-exists? "/tmp/aura-pets-world.txt")
      (world-load! "/tmp/aura-pets-world.txt")
    (world-reset!))
  (set! *d-pet* (pet-make "mochi" "cat" "/tmp/brain" "cat-idle"))
  (combat-reset! *d-pet*)
  (battle-reset!)
  (set! *d-x* (clamp-x (quotient W 4)))
  (set! *d-y* (clamp-y (quotient (+ SCENE-Y0 (- SCENE-Y1 CAT-H)) 2)))
  (set! *d-i* 0)
  (set! *d-n* n)
  (while (lambda () (< *d-i* *d-n*))
         (lambda ()
           (let ((i *d-i*))
             (cond
               ((= i 1)
                (set! *d-pet* (cmd-pet (apply-cmd *d-pet* "1") *d-pet*)))
               ((= i 3)
                (set! *d-pet* (cmd-pet (apply-cmd *d-pet* "2") *d-pet*)))
               ((= i 5)
                (set! *d-pet* (cmd-pet (apply-cmd *d-pet* "3") *d-pet*)))
               ((= i 7)
                (set! *d-pet* (cmd-pet (apply-cmd *d-pet* "1") *d-pet*)))
               ((= i 8)
                (set! *d-pet* (cmd-pet (apply-cmd *d-pet* "e") *d-pet*)))
               (else #t))
             (anim-tick!)
             (pet-render-sync)
             (if (= i 2)
                 (set! *d-x* (clamp-x (+ *d-x* 3)))
               #t)
             (draw-scene! *d-pet* i *d-x* *d-y*)
             (display "\n=== Frame ")
             (display (number->string i))
             (display " size=")
             (display (number->string W))
             (display "x")
             (display (number->string H))
             (display " v")
             (display (number->string (pet-version *d-pet*)))
             (display " anim=")
             (display (anim-kind))
             (display " love=")
             (display (number->string (game-love)))
             (display " npcs=")
             (display (number->string (world-npc-count)))
             (display " ===\n")
             (display (tui:frame-ansi))
             (newline)
             (set! *d-i* (+ i 1)))))
  (tui:show-cursor)
  (tui:shutdown)
  "DONE")
; ── play state (module-level for simpler loop body) ──
(define *p-pet* #f)
(define *p-frame* 0)
(define *p-x* 8)
(define *p-y* 5)
(define *p-running* #t)
(define *p-tick* 0)
(define *p-quit* "unknown")
; Soft vitals interval in frames (~1.5s at ~60fps)
(define *p-soft-every* 90)
; Double-tap dash: last nav dir + frame
(define *dash-dir* "")
(define *dash-frame* -99)
; Double Ctrl+C: engine emits ("quit" . _) on each C-c. First arms; second
; within ~2s (~100 frames @ ~50fps) exits. Ctrl+D (empty prompt) quits once.
(define *ctrl-c-arm-frame* -999)
(define *ctrl-c-window* 100)

(define (evt-tag e)
  (if (and (pair? e) (string? (car e))) (car e) "none"))

(define (evt-pay e)
  (if (and (pair? e) (string? (cdr e))) (cdr e) "-"))

(define (pet-snap pet)
  (string-append "love=" (number->string (game-love))
                 " H=" (number->string (pet-hunger pet))
                 " M=" (number->string (pet-mood pet))
                 " E=" (number->string (pet-energy pet))
                 " v=" (number->string (pet-version pet))
                 " anim=" (anim-kind)
                 " xy=" (number->string *p-x*) "," (number->string *p-y*)))

(define (play-stop! reason)
  (set! *p-quit* reason)
  (set! *p-running* #f)
  (plog "stop" reason)
  #t)

(define (ctrl-c-armed?)
  (and (>= *ctrl-c-arm-frame* 0)
       (< (- *p-frame* *ctrl-c-arm-frame*) *ctrl-c-window*)))

(define (arm-ctrl-c!)
  (set! *ctrl-c-arm-frame* *p-frame*)
  (game-set-speech! "Ctrl+C again to quit (or Ctrl+D)")
  (prompt-set-log! (game-speech))
  (plog "ctrl-c" "armed")
  #t)

(define (clear-ctrl-c-arm!)
  (set! *ctrl-c-arm-frame* -999)
  #t)

; Process one input event. Returns #t always (state via set!).
(define (play-handle-event! e)
  (let ((act (prompt-handle e)))
    (if (or act (and (pair? e) (string? (car e))))
        (plog-event *p-frame*
                    (if (string? act) act "nil")
                    (string-append "tag=" (evt-tag e) " pay=" (evt-pay e)
                                   " " (pet-snap *p-pet*)))
      #t)
    (cond
      ((and (string? act) (string=? act "quit"))
       ; Engine ("quit" . _) = Ctrl+C → need double press.
       ; Key path (Ctrl+D empty) → quit immediately.
       (if (and (pair? e) (string=? (car e) "quit"))
           (if (ctrl-c-armed?)
               (begin
                 (clear-ctrl-c-arm!)
                 (play-stop! "double-ctrl-c")
                 (apply-cmd-world *p-pet* "q")
                 #t)
             (arm-ctrl-c!))
         (begin
           (clear-ctrl-c-arm!)
           (play-stop!
             (string-append "key-quit pay=" (evt-pay e)))
           (apply-cmd-world *p-pet* "q")
           #t)))
      ((and (string? act) (string=? act "nav-left"))
       (nav-apply! "left" -1 0))
      ((and (string? act) (string=? act "nav-right"))
       (nav-apply! "right" 1 0))
      ((and (string? act) (string=? act "nav-up"))
       (nav-apply! "up" 0 -1))
      ((and (string? act) (string=? act "nav-down"))
       (nav-apply! "down" 0 1))
      ((and (string? act) (string=? act "hot"))
       (let* ((cmd (prompt-hot))
              (r (if (string=? cmd "fire")
                     (begin
                       (cmd-set-pos! *p-x* *p-y*)
                       (if (battle-pet-fire! *p-pet* *p-x* *p-y*)
                           (begin
                             (game-set-speech!
                               (string-append "Pew! [" (battle-weapon) "]"))
                             (prompt-set-log! (game-speech))
                             (cons #t *p-pet*))
                         (begin
                           (game-set-speech! "Cooldown charging...")
                           (prompt-set-log! (game-speech))
                           (cons #t *p-pet*))))
                   (apply-cmd-world *p-pet* cmd))))
         (plog "hot" (string-append "cmd=" cmd
                                    " keep=" (if (still-going? r) "1" "0")))
         (set! *p-pet* (cmd-pet r *p-pet*))
         (if (still-going? r)
             #t
           (play-stop! (string-append "hot-cmd-stop=" cmd)))))
      ((and (string? act) (string=? act "submit"))
       (let ((cmd (prompt-take-submit!)))
         (if (= (string-length cmd) 0)
             #t
           (let ((r (apply-cmd-world *p-pet* cmd)))
             (plog "submit" (string-append "cmd=" cmd
                                           " keep=" (if (still-going? r) "1" "0")))
             (set! *p-pet* (cmd-pet r *p-pet*))
             ; Stay INSERT after submit; toast goes to prompt status line.
             (try (prompt-set-log! (game-speech)) (catch (e) #f))
             (if (still-going? r)
                 #t
               (play-stop! (string-append "submit-stop=" cmd)))))))
      ((and (string? act) (string=? act "mode"))
       ; Esc / i / : — refresh status from prompt-log
       (try (prompt-set-log! (prompt-log)) (catch (e) #f))
       (plog "mode" (try (prompt-mode) (catch (e) "?")))
       #t)
      (else #t))))
; Apply finished async NL / worldgen without blocking the move loop.
(define (play-poll-async!)
  (try
    (let ((msg (nl-poll!)))
      (if msg
          (begin
            (game-set-speech! msg)
            (prompt-set-log! msg)
            ; Keep log short — edsl-show/string-append of huge state can OOM stack.
            (plog "nl" (string-append "async-done src=" (nl-last-src)
                                      " npcs=" (number->string (world-npc-count))))
            #t)
        #f))
    (catch (e)
      (begin
        (plog "nl" "async-apply-exception")
        (game-set-speech! "Update skipped — keep playing!")
        (prompt-set-log! (game-speech))
        #f))))

(define (play-step!)
  ; 1) Input FIRST so keys stay responsive even if draw is busy.
  (play-drain-input!)
  ; 2) Deferred NL/worldgen (cheap poll).
  (play-poll-async!)
  (anim-tick!)
  (pet-render-sync)
  ; 3) Simulate (npc AI every other frame to save CPU)
  (if (= (modulo *p-frame* 2) 0)
      (world-tick-npcs! *p-frame* W SCENE-Y0 SCENE-Y1)
    #t)
  (battle-set-bounds! 0 SCENE-Y0 W SCENE-Y1)
  (battle-tick! *p-pet* *p-x* *p-y*)
  ; 4) Draw
  (draw-scene! *p-pet* *p-frame* *p-x* *p-y*)
  (set! *p-frame* (+ *p-frame* 1))
  (set! *p-tick* (+ *p-tick* 1))
  (if (and *p-running*
           (> *p-soft-every* 0)
           (= (modulo *p-tick* *p-soft-every*) 0))
      (begin
        (set! *p-pet* (game-soft-tick *p-pet*))
        ; Surface self-evolution toast on the prompt status line.
        (if (string=? (game-last-act) "evolve-code")
            (begin
              (prompt-set-log! (game-speech))
              (plog "genome" (try (genome-line) (catch (e) "tick-evo"))))
          #t)
        (plog "tick" (pet-snap *p-pet*)))
    #t)
  #t)

(define (cat-demo-interactive)
  ; 1) Raw mode first so TIOCGWINSZ sees the real TTY size.
  (tui:raw-mode-on)
  (layout-fit!)
  ; 2) Single init at measured full-terminal size (no mid-start shutdown/re-init).
  (tui:init "aura-pets" W H #t)
  (tui:hide-cursor)
  (prompt-init! PROMPT-Y)
  (prompt-set-width! W)
  ; Quit: Ctrl+D (empty line) or double Ctrl+C — not bare "q".
  (prompt-set-no-q-quit! #t)
  ; Start in NORMAL (game-first); press i to open INSERT prompt box.
  (try (prompt-enter-normal!) (catch (e) #f))
  (game-reset!)
  (morph-reset!)
  (set! *p-pet* (pet-make "mochi" "cat" "/tmp/brain" "cat-idle"))
  (combat-reset! *p-pet*)
  (battle-reset!)
  (set! *dash-dir* "")
  (set! *dash-frame* -99)
  (set! *ctrl-c-arm-frame* -999)
  (set! *p-frame* 0)
  (set! *p-x* (clamp-x (quotient W 4)))
  (set! *p-y* (clamp-y (quotient (+ SCENE-Y0 (- SCENE-Y1 CAT-H)) 2)))
  (set! *p-running* #t)
  (set! *p-tick* 0)
  (set! *p-quit* "unknown")
  (plog-start! (plog-path))
  (plog "info" (string-append "term=" (number->string W) "x" (number->string H)
                              " scene=" (number->string SCENE-Y0)
                              ".." (number->string SCENE-Y1)
                              " " (pet-snap *p-pet*)))
  (plog-flush!)
  ; Small default world only — no auto async worldgen (was crashing large TTY).
  (world-set-path! "/tmp/aura-pets-world.txt")
  (world-reset!)
  (plog "world" (string-append "theme=" (world-theme)
                               " npcs=" (number->string (world-npc-count))
                               " async=0"))
  (plog-flush!)
  (try (plog "genome" (genome-line)) (catch (e) #f))
  ; Optional continue: AURA_PETS_CONTINUE=1 or ./run.sh play --continue
  ; New life: friendly tip pointing at interactive /tutorial guide (not a forced tour).
  (if (try (play-maybe-continue!) (catch (e) #f))
      (try (tut-off!) (catch (e) #f))
    (try
      (begin
        (tut-welcome!)
        (prompt-set-log! (game-speech))
        (plog "tutorial" "welcome-tip"))
      (catch (e)
        (begin
          (game-set-speech!
            (string-append "Welcome! " (world-theme)
                           " | /tutorial for guide | C-d quit"))
          (prompt-set-log! (game-speech))))))
  (plog "ready" "entering-play-loop")
  (plog-flush!)
  ; Frame pacing. Aura has no tui:sleep — shell sleep has ~few-ms fork cost.
  ; 0.008 target ~50–60fps wall when draw is light (was 0.030 ≈ 25fps, laggy).
  ; Override: AURA_PETS_FRAME_SLEEP=0.016 for calmer terminals.
  (define *p-frame-sleep*
    (try
      (let ((e (getenv "AURA_PETS_FRAME_SLEEP")))
        (if (and (string? e) (> (string-length e) 0)) e "0.008"))
      (catch (e) "0.008")))
  ; Host (while pred body) runs in C++ — no Scheme stack growth per frame.
  (while (lambda () *p-running*)
         (lambda ()
           (try
             (begin
               (if (= *p-frame* 0)
                   (begin (plog "frame" "first-play-step") (plog-flush!))
                 #t)
               (play-step!)
               (if (= *p-frame* 1)
                   (begin (plog "frame" "first-ok") (plog-flush!))
                 #t)
               (try (shell (string-append "sleep " *p-frame-sleep*))
                    (catch (e) #f)))
             (catch (err)
               (begin
                 (play-stop! "exception")
                 (plog "ERROR" "play-step-exception")
                 (plog-flush!))))))
  (plog-quit *p-quit* *p-frame* (pet-snap *p-pet*))
  ; Auto-save life progress + debug export copy.
  (try
    (begin
      (pet-save-default!)
      (plog "save" (try (save-latest-path) (catch (e) "latest")))
      (try (pet-export! (save-empty)) (catch (e) #f)))
    (catch (e) (plog "save" "failed")))
  (prompt-set-log!
    (string-append "bye (" *p-quit* ") saved="
                   (try (save-latest-path) (catch (e) "?"))
                   " log=" (plog-path)))
  ; Restore terminal before last paint so block cursor / tty cursor come back.
  (tui:show-cursor)
  (draw-scene! *p-pet* *p-frame* *p-x* *p-y*)
  (tui:raw-mode-off)
  (tui:show-cursor)
  (tui:shutdown)
  (plog-end! *p-quit*)
  "BYE")

(define (play-entry)
  (cat-demo-interactive)
  #t)

; After interactive setup, optionally restore save (--continue).
; Called from cat-demo-interactive after game-reset! when env set.
(define (play-maybe-continue!)
  (if (try (pet-should-continue?) (catch (e) #f))
      (let ((ok (try (pet-load-default!) (catch (e) #f))))
        (if ok
            (begin
              (game-set-speech! (try (save-last-toast) (catch (e) "Restored!")))
              (prompt-set-log! (game-speech))
              (plog "load" (try (save-last-toast) (catch (e) "ok")))
              #t)
          (begin
            (plog "load" "no-save-or-fail")
            #f)))
    #f))

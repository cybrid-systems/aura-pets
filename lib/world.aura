; lib/world.aura — background + NPC world for aura-pets (business).
;
; World file format:
;   theme:Name
;   bg:meadow|cyber|matrix|stars|city|ocean|grid|sunset|recipe
;   sky:r,g,b  sky2: floor: floor2: star: accent:
;   rain:N   (matrix rain drop count)
;   layers:rain,12|dots,3|stars|waves|skyline|grid,8,4|petals,2
;   npc:Name|x|y|kind|speech
;   prop:tree|x|y
;
; Background model (Slice A+B):
;   palette colors always drive fill; layers list is a sparse recipe
;   the local drawer interprets every frame (LLM never paints cells).
;
; API:
;   (world-reset!) (world-load! path) (world-generate! cols rows)
;   (world-draw-bg! w h y0 y1 frame) (world-draw-npcs! frame)
;   (world-theme) (world-bg-style) (world-set-bg-style! s)
;   (world-set-layers-str! s) (world-recipe-summary)
;   (world-npc-count) (world-nearest-speech x y)

(define *world-theme* "Meadow")
; Patterned backgrounds (not hard sky/floor stripes):
;   meadow sunset ocean stars city grid cyber matrix recipe
(define *bg-style* "meadow")
(define *world-npcs* '())
(define *world-props* '())
; Packed RGB ints (same layout as canvas rgb) — avoid depending on canvas load order.
(define (world-rgb r g b) (+ (* r 65536) (* g 256) b))
(define *w-sky* 1973790)
(define *w-sky2* 2963010)
(define *w-floor* 3635269)
(define *w-floor2* 2654258)
(define *w-star* 15132415)
(define *w-accent* 16742590)  ; neon pink default highlight
(define *world-path* "/tmp/aura-pets-world.txt")
(define *world-ok* #f)
; Cyber/matrix rain: list of (x y speed seed)
(define *bg-rain* '())
(define *bg-rain-ready* #f)
; Recipe params (Slice A)
(define *bg-rain-n* 12)
(define *bg-dot-step* 3)
(define *bg-grid-x* 12)
(define *bg-grid-y* 6)
; Layer list: each entry is (kind . args-list-of-strings) e.g. ("rain" "12")
; Empty → rebuild from style defaults on next set-style.
(define *bg-layers* '())

(define (world-empty) (substring "x" 0 0))

(define (world-theme) *world-theme*)
(define (world-bg-style) *bg-style*)
(define (world-npc-count) (length *world-npcs*))
(define (world-ok?) *world-ok*)
(define (world-path) *world-path*)
(define (world-accent) *w-accent*)
(define (world-layers) *bg-layers*)

(define (world-set-path! p)
  (set! *world-path* p)
  #t)

(define (world-set-accent! c)
  (if (number? c) (set! *w-accent* c) #t)
  #t)

(define (world-set-rain-n! n)
  (let ((v (if (and (number? n) (> n 0)) n 12)))
    (if (> v 24) (set! *bg-rain-n* 24) (set! *bg-rain-n* v))
    (set! *bg-rain-ready* #f)
    #t))

(define (world-set-dot-step! n)
  (let ((v (if (and (number? n) (> n 0)) n 3)))
    (if (> v 8) (set! *bg-dot-step* 8) (set! *bg-dot-step* v))
    #t))

; Clamp int from string, default d.
(define (world-num-or s d)
  (let ((v (try (string->number s) (catch (e) #f))))
    (if (number? v) v d)))

; Default sparse layers for a named preset (Slice B recipes-as-data).
(define (world-default-layers-for style)
  (cond
    ((or (string=? style "cyber") (string=? style "matrix"))
     (list (list "grid" (number->string *bg-grid-x*) (number->string *bg-grid-y*))
           (list "rain" (number->string *bg-rain-n*))))
    ((string=? style "grid")
     (list (list "grid" "8" "4")))
    ((string=? style "stars")
     (list (list "stars")))
    ((string=? style "ocean")
     (list (list "waves")))
    ((string=? style "city")
     (list (list "skyline") (list "stars")))
    ((string=? style "sunset")
     (list (list "stars") (list "dots" (number->string *bg-dot-step*))))
    ((string=? style "meadow")
     (list (list "dots" (number->string *bg-dot-step*))))
    (else
     (list (list "dots" "3")))))

(define (world-load-default-layers!)
  (set! *bg-layers* (world-default-layers-for *bg-style*))
  (set! *bg-rain-ready* #f)
  #t)

; Parse "rain,12|dots,3|stars|grid,8,4|petals,2" → layer list.
(define (world-parse-layers-str s)
  (let ((n (string-length s)))
    (if (= n 0)
        '()
      (let loop ((i 0) (start 0) (acc '()))
        (if (>= i n)
            (let ((chunk (if (>= start n) "" (substring s start n))))
              (if (= (string-length chunk) 0)
                  (reverse acc)
                (reverse (cons (world-parse-layer-chunk chunk) acc))))
          (if (string=? (substring s i (+ i 1)) "|")
              (let ((chunk (substring s start i)))
                (loop (+ i 1) (+ i 1)
                      (if (= (string-length chunk) 0)
                          acc
                        (cons (world-parse-layer-chunk chunk) acc))))
            (loop (+ i 1) start acc)))))))

; "rain,12" or "stars" → ("rain" "12") / ("stars")
(define (world-parse-layer-chunk chunk)
  (let ((n (string-length chunk)))
    (let loop ((i 0) (start 0) (parts '()))
      (if (>= i n)
          (let ((last (if (>= start n) "" (substring chunk start n))))
            (if (= (string-length last) 0)
                (reverse parts)
              (reverse (cons last parts))))
        (if (string=? (substring chunk i (+ i 1)) ",")
            (begin
              (loop (+ i 1) (+ i 1)
                    (cons (substring chunk start i) parts)))
          (loop (+ i 1) start parts))))))

(define (world-set-layers-str! s)
  (let ((ls (world-parse-layers-str s)))
    (set! *bg-layers* ls)
    ; Pull params from first rain/dots/grid if present
    (let loop ((xs ls))
      (if (null? xs) #t
        (let* ((L (car xs))
               (k (if (pair? L) (car L) "")))
          (cond
            ((string=? k "rain")
             (if (and (pair? (cdr L)) (string? (car (cdr L))))
                 (world-set-rain-n! (world-num-or (car (cdr L)) 12))
               #t))
            ((or (string=? k "dots") (string=? k "petals"))
             (if (and (pair? (cdr L)) (string? (car (cdr L))))
                 (world-set-dot-step! (world-num-or (car (cdr L)) 3))
               #t))
            ((string=? k "grid")
             (if (and (pair? (cdr L)) (string? (car (cdr L))))
                 (set! *bg-grid-x* (world-num-or (car (cdr L)) 12))
               #t)
             (if (and (pair? (cdr L)) (pair? (cdr (cdr L)))
                      (string? (car (cdr (cdr L)))))
                 (set! *bg-grid-y* (world-num-or (car (cdr (cdr L))) 6))
               #t))
            (else #t))
          (loop (cdr xs)))))
    (set! *bg-rain-ready* #f)
    (set! *world-ok* #t)
    #t))

; Serialize layers back to ops string.
(define (world-layers-str)
  (let loop ((xs *bg-layers*) (acc (world-empty)) (first #t))
    (if (null? xs) acc
      (let* ((L (car xs))
             (chunk
               (let loop2 ((ps L) (c (world-empty)) (f2 #t))
                 (if (null? ps) c
                   (loop2 (cdr ps)
                          (if f2 (car ps)
                            (string-append c "," (car ps)))
                          #f)))))
        (loop (cdr xs)
              (if first chunk (string-append acc "|" chunk))
              #f)))))

; One-line recipe toast for /bg and speech.
(define (world-recipe-summary)
  (let ((ls (world-layers-str)))
    (string-append
      "bg=" *bg-style*
      " rain=" (number->string *bg-rain-n*)
      " layers="
      (if (= (string-length ls) 0) "(default)" ls))))

; Short substring search (theme/style names only — keep n small).
(define (world-has? s sub)
  (let ((n (string-length s))
        (m (string-length sub)))
    (if (or (= m 0) (> m n)) #f
      (let loop ((i 0))
        (if (> (+ i m) n) #f
          (if (string=? (substring s i (+ i m)) sub) #t
            (loop (+ i 1))))))))

(define (world-infer-bg-style! name)
  (let ((t name))
    (cond
      ((or (world-has? t "cyber") (world-has? t "Cyber")
           (world-has? t "matrix") (world-has? t "Matrix")
           (world-has? t "neon") (world-has? t "Neon")
           (world-has? t "赛博") (world-has? t "矩阵"))
       (world-set-bg-style! "cyber"))
      ((or (world-has? t "star") (world-has? t "Star")
           (world-has? t "night") (world-has? t "Night")
           (world-has? t "space") (world-has? t "夜"))
       (world-set-bg-style! "stars"))
      ((or (world-has? t "ocean") (world-has? t "Ocean")
           (world-has? t "beach") (world-has? t "Beach")
           (world-has? t "sea") (world-has? t "海"))
       (world-set-bg-style! "ocean"))
      ((or (world-has? t "city") (world-has? t "City")
           (world-has? t "urban") (world-has? t "城"))
       (world-set-bg-style! "city"))
      ((or (world-has? t "grid") (world-has? t "Grid"))
       (world-set-bg-style! "grid"))
      ((or (world-has? t "sunset") (world-has? t "Sunset")
           (world-has? t "dusk"))
       (world-set-bg-style! "sunset"))
      (else (world-set-bg-style! "meadow")))))

; ── Live mutators (NL / eDSL hot path) ──
(define (world-set-theme! name)
  (set! *world-theme* name)
  (world-infer-bg-style! name)
  (set! *world-ok* #t)
  #t)
(define (world-set-bg-style! s)
  (set! *bg-style*
    (cond
      ((or (string=? s "cyber") (string=? s "matrix") (string=? s "neon"))
       "cyber")
      ((or (string=? s "stars") (string=? s "star") (string=? s "night"))
       "stars")
      ((or (string=? s "ocean") (string=? s "beach") (string=? s "sea"))
       "ocean")
      ((or (string=? s "city") (string=? s "urban")) "city")
      ((string=? s "grid") "grid")
      ((or (string=? s "sunset") (string=? s "dusk")) "sunset")
      ((or (string=? s "meadow") (string=? s "park") (string=? s "grass"))
       "meadow")
      ((or (string=? s "recipe") (string=? s "custom")) "recipe")
      (else s)))
  ; Load default layer recipe for this preset (LLM can override via layers:)
  (if (string=? *bg-style* "recipe")
      (if (null? *bg-layers*)
          (set! *bg-layers* (list (list "dots" "3") (list "stars")))
        #t)
    (world-load-default-layers!))
  (set! *bg-rain-ready* #f)
  (set! *world-ok* #t)
  #t)
(define (world-set-sky! c) (if (number? c) (set! *w-sky* c) #t) #t)
(define (world-set-sky2! c) (if (number? c) (set! *w-sky2* c) #t) #t)
(define (world-set-floor! c) (if (number? c) (set! *w-floor* c) #t) #t)
(define (world-set-floor2! c) (if (number? c) (set! *w-floor2* c) #t) #t)
(define (world-set-star! c)
  (if (number? c)
      (begin (set! *w-star* c) (set! *w-accent* c))
    #t)
  #t)
(define (world-clear-npcs!) (set! *world-npcs* '()) #t)
(define (world-clear-props!) (set! *world-props* '()) #t)
; Keep entity counts modest for TUI frame budget + eval stack safety.
; ~6 NPCs: readable, playable, and lighter draw path.
(define *world-max-npcs* 6)
(define *world-max-props* 12)

(define (world-add-npc! npc)
  (if (>= (length *world-npcs*) *world-max-npcs*)
      #f
    (begin
      ; Keep raw record; entity.aura normalizes on query/patch (Aura try
      ; returns status, not value — do not wrap npc-normalize in try here).
      (set! *world-npcs* (append *world-npcs* (list npc)))
      (set! *world-ok* #t)
      #t)))
(define (world-add-prop! pr)
  (if (>= (length *world-props*) *world-max-props*)
      #f
    (begin
      (set! *world-props* (append *world-props* (list pr)))
      #t)))

; Remove first NPC matching name (fainted in combat).
(define (world-remove-npc-name! name)
  (set! *world-npcs*
    (let loop ((xs *world-npcs*) (acc '()))
      (if (null? xs)
          (reverse acc)
        (if (string=? (car (car xs)) name)
            (loop (cdr xs) acc)
          (loop (cdr xs) (cons (car xs) acc))))))
  #t)

(define (world-npcs) *world-npcs*)

; ── Dynamic sprite storage (LLM-defined creatures/objects) ──
; Sprite = (name w h pixels). pixels is a flat list of packed RGB ints,
; length = w*h, in row-major order. LLM emits `sprite:<name>|<w>|<h>
; |<r>,<g>,<b>|...` to define one; NPCs/props then reference the name.
; This is the eDSL mutation surface for "render new content": Aura's
; data-as-data layer (DESIGN.md §eDSL Layer A) lets the LLM hot-load
; arbitrary sprites without `set-code` / workspace touch.
(define *world-sprites* '())

(define (world-sprite-add! sprite)
  (set! *world-sprites*
    (let loop ((xs *world-sprites*) (acc '()))
      (cond
        ((null? xs) (cons sprite acc))
        ((string=? (car (car xs)) (car sprite))
         (append (reverse acc) (cons sprite (cdr xs))))
        (else (loop (cdr xs) (cons (car xs) acc)))))))

(define (world-sprite-get name)
  (let loop ((xs *world-sprites*))
    (if (null? xs) #f
      (if (string=? (car (car xs)) name)
          (car xs)
          (loop (cdr xs))))))

; Draw sprite at (x, y) using tui:pixel with same top/bot (solid color).
; Static (no bob/wig): dynamic sprites don't have the natural creature
; animation that the hardcoded NPC sprite has.
(define (world-sprite-draw! sprite x y)
  (let* ((w (car (cdr sprite)))
         (h (car (cdr (cdr sprite))))
         (pixels (car (cdr (cdr (cdr sprite))))))
    (let loop ((i 0) (ps pixels))
      (if (null? ps) #t
        (let* ((col (modulo i w))
               (row (quotient i w))
               (rgb (car ps)))
          (world-px (+ x col) (+ y row) rgb rgb)
          (loop (+ i 1) (cdr ps)))))))

; Find first "|" in s starting at i. Returns -1 if not found.
(define (find-bar s i)
  (let ((n (string-length s)))
    (let loop ((j i))
      (cond
        ((>= j n) -1)
        ((string=? (substring s j (+ j 1)) "|") j)
        (else (loop (+ j 1)))))))

; Parse `|`-separated list of r,g,b triples.
(define (parse-rgb-list s)
  (let ((n (string-length s)))
    (let loop ((i 0) (acc '()))
      (if (>= i n) (reverse acc)
        (let find-bar ((j i))
          (cond
            ((>= j n)
             (let ((triple (parse-rgb (substring s i j))))
               (if triple (reverse (cons triple acc)) '())))
            ((string=? (substring s j (+ j 1)) "|")
             (let ((triple (parse-rgb (substring s i j))))
               (if triple (loop (+ j 1) (cons triple acc)) '())))
            (else (find-bar (+ j 1)))))))))

; Parse `sprite:<name>|<w>|<h>|<r>,<g>,<b>|...`.
; Sprite size limited to 16 wide × 12 tall (LLM token budget + screen).
(define (parse-sprite line)
  (let* ((body (substring line 7 (string-length line)))
         (n (string-length body))
         (p1 (find-bar body 0))
         (p2 (if (> p1 -1) (find-bar body (+ p1 1)) -1)))
    (if (or (< p1 0) (< p2 0))
        #f
        (let* ((name (substring body 0 p1))
               (w (string->number (substring body (+ p1 1) p2)))
               (h (string->number (substring body (+ p2 1) n)))
               (rest (substring body (+ p2 1) n))
               (pixels (parse-rgb-list rest)))
          (if (and w h (>= w 1) (<= w 16) (>= h 1) (<= h 12)
                   (= (length pixels) (* w h))
                   (> (string-length name) 0))
              (list name w h pixels)
              #f)))))

; Sprite name from NPC record (6-field). Returns #f if absent.
(define (npc-sprite-name n)
  (if (>= (length n) 6)
      (let ((s (car (cdr (cdr (cdr (cdr (cdr n))))))))
        (if (and (string? s) (> (string-length s) 0)) s #f))
      #f))

; Sprite name from prop record (4-field). Returns #f if absent.
(define (prop-sprite-name p)
  (if (>= (length p) 4)
      (let ((s (car (cdr (cdr (cdr p)))))
        (if (and (string? s) (> (string-length s) 0)) s #f))
      #f))

; Serialize sprite back to "sprite:<name>|<w>|<h>|<r>,<g>,<b>|..." line.
(define (world-sprite-to-line sprite)
  (let* ((name (car sprite))
         (w (car (cdr sprite)))
         (h (car (cdr (cdr sprite))))
         (pixels (car (cdr (cdr (cdr sprite)))))
         (head (string-append "sprite:" name "|"
                              (number->string w) "|"
                              (number->string h) "|"))
         (body (let loop ((ps pixels) (acc head))
                 (if (null? ps) acc
                   (let* ((p (car ps))
                          (rgb-str (world-rgb-str p)))
                     (loop (cdr ps)
                           (string-append acc rgb-str "|")))))))
    ; Strip trailing "|"
    (substring body 0 (- (string-length body) 1))))

; Unpack packed rgb → "r,g,b" for save / AST source.
(define (world-rgb-str packed)
  (let* ((r (quotient packed 65536))
         (g (quotient (modulo packed 65536) 256))
         (b (modulo packed 256)))
    (string-append (number->string r) ","
                   (number->string g) ","
                   (number->string b))))

; Persist current in-memory world to *world-path* (line format).
(define (world-save!)
  (let ((s (world-to-file-text)))
    (try
      (begin (write-file *world-path* s) #t)
      (catch (e) #f))))

(define (world-to-file-text)
  (let* ((ls (world-layers-str))
         (head (string-append
                 "theme:" *world-theme* "\n"
                 "bg:" *bg-style* "\n"
                 "sky:" (world-rgb-str *w-sky*) "\n"
                 "sky2:" (world-rgb-str *w-sky2*) "\n"
                 "floor:" (world-rgb-str *w-floor*) "\n"
                 "floor2:" (world-rgb-str *w-floor2*) "\n"
                 "star:" (world-rgb-str *w-star*) "\n"
                 "accent:" (world-rgb-str *w-accent*) "\n"
                 "rain:" (number->string *bg-rain-n*) "\n"
                 (if (> (string-length ls) 0)
                     (string-append "layers:" ls "\n")
                   (world-empty))))
         (with-sprites
           (let loop ((xs *world-sprites*) (acc head))
             (if (null? xs) acc
               (loop (cdr xs)
                     (string-append acc
                       (world-sprite-to-line (car xs)) "\n")))))
         (with-npcs
           (let loop ((xs *world-npcs*) (acc with-sprites))
             (if (null? xs) acc
               (let* ((n (car xs))
                      (sprite (npc-sprite-name n))
                      (line (string-append
                              "npc:" (car n) "|"
                              (number->string (car (cdr n))) "|"
                              (number->string (car (cdr (cdr n)))) "|"
                              (car (cdr (cdr (cdr n)))) "|"
                              (car (cdr (cdr (cdr (cdr n)))))
                              (if (and sprite (string? sprite)
                                            (> (string-length sprite) 0))
                                  (string-append "|" sprite)
                                (world-empty))
                              "\n")))
                 (loop (cdr xs) (string-append acc line))))))
         (with-props
           (let loop ((xs *world-props*) (acc with-npcs))
             (if (null? xs) acc
               (let* ((p (car xs))
                      (sprite (prop-sprite-name p))
                      (line (string-append
                              "prop:" (car p) "|"
                              (number->string (car (cdr p))) "|"
                              (number->string (car (cdr (cdr p))))
                              (if (and sprite (string? sprite)
                                            (> (string-length sprite) 0))
                                  (string-append "|" sprite)
                                (world-empty))
                              "\n")))
                 (loop (cdr xs) (string-append acc line)))))))
    with-props))

; Emit Aura source rebinding world state (for set-code / AST hot update).
(define (world-to-aura-source)
  (let* ((s0 (string-append
               "(set! *world-theme* \"" *world-theme* "\")\n"
               "(set! *bg-style* \"" *bg-style* "\")\n"
               "(set! *w-sky* " (number->string *w-sky*) ")\n"
               "(set! *w-sky2* " (number->string *w-sky2*) ")\n"
               "(set! *w-floor* " (number->string *w-floor*) ")\n"
               "(set! *w-floor2* " (number->string *w-floor2*) ")\n"
               "(set! *w-star* " (number->string *w-star*) ")\n"))
         (s0 (let loop ((xs *world-sprites*) (acc s0))
               (if (null? xs) (string-append acc "(set! *world-sprites* (list))\n")
                 (let loop2 ((xs2 xs) (acc2 "(set! *world-sprites* (list"))
                   (if (null? xs2)
                       (loop (cdr xs) (string-append acc2 "))\n"))
                       (let* ((s (car xs2))
                              (px (car (cdr (cdr (cdr s)))))
                              (px-str (let loop3 ((ps px) (acc3 ""))
                                       (if (null? ps) acc3
                                         (loop3 (cdr ps)
                                                (string-append acc3
                                                  (number->string (car ps))
                                                  (if (null? (cdr ps)) "" " ")))))))
                         (loop2 (cdr xs2)
                                (string-append acc2
                                  "\n  (list \"" (car s) "\" "
                                  (number->string (car (cdr s))) " "
                                  (number->string (car (cdr (cdr s))))
                                  " (list " px-str "))")))))))))
         (s1 (string-append s0 "(set! *world-npcs* (list"))
         (s2 (let loop ((xs *world-npcs*) (acc s1))
               (if (null? xs) acc
                 (let* ((n (car xs))
                        (sprite (npc-sprite-name n))
                        (sprite-form (if (and sprite (string? sprite)
                                               (> (string-length sprite) 0))
                                        (string-append " \"" sprite "\"")
                                        " #f"))
                        (entry (string-append
                                 " (list \"" (car n) "\" "
                                 (number->string (car (cdr n))) " "
                                 (number->string (car (cdr (cdr n)))) " \""
                                 (car (cdr (cdr (cdr n)))) "\" \""
                                 (car (cdr (cdr (cdr (cdr n))))) "\""
                                 sprite-form ")")))
                   (loop (cdr xs) (string-append acc entry))))))
         (s3 (string-append s2 "))\n(set! *world-props* (list"))
         (s4 (let loop ((xs *world-props*) (acc s3))
               (if (null? xs) acc
                 (let* ((p (car xs))
                        (sprite (prop-sprite-name p))
                        (sprite-form (if (and sprite (string? sprite)
                                               (> (string-length sprite) 0))
                                        (string-append " \"" sprite "\"")
                                        " #f"))
                        (entry (string-append
                                 " (list \"" (car p) "\" "
                                 (number->string (car (cdr p))) " "
                                 (number->string (car (cdr (cdr p))))
                                 sprite-form ")")))
                   (loop (cdr xs) (string-append acc entry))))))
         (s5 (string-append s4 "))\n(set! *world-ok* #t)\n")))
    s5))

; Play-safe commit: only world-save! (line file). Skip huge to-aura-source
; and ast:snapshot under load — both have crashed eval_flat mid-session.
; Returns "save" | "local".
(define (world-aura-commit!)
  (try
    (begin (world-save!) "save")
    (catch (e) "local")))

; Parse "r,g,b" → packed rgb int (same as canvas rgb).
(define (parse-rgb s)
  (let ((n (string-length s)))
    (let find1 ((i 0))
      (if (>= i n)
          0
        (if (string=? (substring s i (+ i 1)) ",")
            (let find2 ((j (+ i 1)))
              (if (>= j n)
                  0
                (if (string=? (substring s j (+ j 1)) ",")
                    (let ((r (string->number (substring s 0 i)))
                          (g (string->number (substring s (+ i 1) j)))
                          (b (string->number (substring s (+ j 1) n))))
                      (if (and (number? r) (number? g) (number? b))
                          (+ (* r 65536) (* g 256) b)
                        0))
                  (find2 (+ j 1)))))
          (find1 (+ i 1)))))))
(define (world-reset!)
  (set! *world-theme* "Sunset Meadow")
  ; Empty cast — the player's pet cat (mochi) is always drawn separately
  ; by draw-pixel-cat!, so the initial world is just a clean bg + the pet.
  ; NPCs/props appear when the player describes them (LLM) or via /world regen.
  (set! *world-npcs* '())
  (set! *world-props* '())
  (set! *w-sky* (world-rgb 40 30 90))
  (set! *w-sky2* (world-rgb 90 50 70))
  (set! *w-floor* (world-rgb 55 110 65))
  (set! *w-floor2* (world-rgb 40 90 50))
  (set! *w-star* (world-rgb 255 220 160))
  (set! *w-accent* (world-rgb 255 180 120))
  (set! *bg-rain-n* 12)
  (set! *bg-dot-step* 3)
  (world-set-bg-style! "sunset")
  (set! *world-ok* #t)
  #t)

; Apply cyber palette (for LLM / offline "cyber cat" prompt).
(define (world-apply-cyber-palette!)
  (set! *w-sky* (world-rgb 0 8 18))
  (set! *w-sky2* (world-rgb 0 20 35))
  (set! *w-floor* (world-rgb 10 15 30))
  (set! *w-floor2* (world-rgb 5 10 20))
  (set! *w-star* (world-rgb 0 255 120))
  (set! *w-accent* (world-rgb 0 255 120))
  (world-set-rain-n! 14)
  (world-set-bg-style! "cyber")
  #t)

; Split path fields for npc: Name|x|y|kind|speech[|sprite]
; 5 fields is the default; 6th field (sprite) is optional.
(define (world-parse-npc line)
  ; line without "npc:" prefix
  (let ((body (substring line 4 (string-length line))))
    (let* ((n (string-length body))
           (p1 -1) (p2 -1) (p3 -1) (p4 -1) (p5 -1))
      (let loop ((i 0) (count 0))
        (if (>= i n) #f
          (if (string=? (substring body i (+ i 1)) "|")
              (begin
                (if (= count 0) (set! p1 i) #t)
                (if (= count 1) (set! p2 i) #t)
                (if (= count 2) (set! p3 i) #t)
                (if (= count 3) (set! p4 i) #t)
                (if (= count 4) (set! p5 i) #t)
                (loop (+ i 1) (+ count 1)))
            (loop (+ i 1) count))))
      (if (or (< p1 0) (< p2 0) (< p3 0) (< p4 0))
          #f
        (let* ((name (substring body 0 p1))
               (xs (substring body (+ p1 1) p2))
               (ys (substring body (+ p2 1) p3))
               (kind (substring body (+ p3 1) p4))
               (speech-end (if (< p5 0) n p5))
               (speech (substring body (+ p4 1) speech-end))
               (sprite (if (< p5 0) #f (substring body (+ p5 1) n))))
          ; Extended play-safe record (entity.aura normalizes to full schema).
          ; Keep 6-field core for draw/combat; entity accessors fill defaults.
          (list name
                (string->number xs)
                (string->number ys)
                kind
                speech
                sprite))))))

; Split path fields for prop: kind|x|y[|sprite]
; 3 fields is the default; 4th field (sprite) is optional.
(define (world-parse-prop line)
  (let ((body (substring line 5 (string-length line))))
    (let* ((n (string-length body))
           (p1 -1) (p2 -1) (p3 -1))
      (let loop ((i 0) (count 0))
        (if (>= i n) #f
          (if (string=? (substring body i (+ i 1)) "|")
              (begin
                (if (= count 0) (set! p1 i) #t)
                (if (= count 1) (set! p2 i) #t)
                (if (= count 2) (set! p3 i) #t)
                (loop (+ i 1) (+ count 1)))
            (loop (+ i 1) count))))
      (cond
        ((or (< p1 0) (< p2 0)) #f)
        ((< p3 0)
         ; 3 fields: kind|x|y
         (list (substring body 0 p1)
               (string->number (substring body (+ p1 1) p2))
               (string->number (substring body (+ p2 1) n))
               #f))
        (else
         ; 4 fields: kind|x|y|sprite
         (list (substring body 0 p1)
               (string->number (substring body (+ p1 1) p2))
               (string->number (substring body (+ p2 1) p3))
               (substring body (+ p3 1) n)))))))

; Apply one line into world state.
(define (world-apply-line! line)
  (let ((n (string-length line)))
    (if (= n 0)
        #f
      (if (and (>= n 6) (string=? (substring line 0 6) "theme:"))
          (begin (set! *world-theme* (substring line 6 n)) #t)
        (if (and (>= n 4) (string=? (substring line 0 4) "sky:")
                 (not (and (>= n 5) (string=? (substring line 0 5) "sky2:"))))
            (begin (set! *w-sky* (parse-rgb (substring line 4 n))) #t)
          (if (and (>= n 5) (string=? (substring line 0 5) "sky2:"))
              (begin (set! *w-sky2* (parse-rgb (substring line 5 n))) #t)
            (if (and (>= n 6) (string=? (substring line 0 6) "floor:")
                     (not (and (>= n 7) (string=? (substring line 0 7) "floor2:"))))
                (begin (set! *w-floor* (parse-rgb (substring line 6 n))) #t)
              (if (and (>= n 7) (string=? (substring line 0 7) "floor2:"))
                  (begin (set! *w-floor2* (parse-rgb (substring line 7 n))) #t)
                (if (and (>= n 5) (string=? (substring line 0 5) "star:"))
                    (begin (world-set-star! (parse-rgb (substring line 5 n))) #t)
                  (if (and (>= n 7) (string=? (substring line 0 7) "accent:"))
                      (begin (world-set-accent! (parse-rgb (substring line 7 n))) #t)
                    (if (and (>= n 5) (string=? (substring line 0 5) "rain:"))
                        (begin
                          (world-set-rain-n!
                            (world-num-or (substring line 5 n) 12))
                          #t)
                      (if (and (>= n 7) (string=? (substring line 0 7) "layers:"))
                          (begin
                            (world-set-layers-str! (substring line 7 n))
                            #t)
                        (if (and (>= n 3) (string=? (substring line 0 3) "bg:"))
                            (begin (world-set-bg-style! (substring line 3 n)) #t)
                          (if (and (>= n 4) (string=? (substring line 0 4) "npc:"))
                              (let ((npc (world-parse-npc line)))
                                (if npc (world-add-npc! npc) #f))
                            (if (and (>= n 5) (string=? (substring line 0 5) "prop:"))
                                (let ((pr (world-parse-prop line)))
                                  (if pr (world-add-prop! pr) #f))
                              #f)))))))))))))))

; Split file text by newlines and apply.
; IMPORTANT: use host (while) — named-let per character is NOT TCO'd in Aura
; and SIGSEGVs once the file is ~1KB+ (each eval_flat frame ≈ 8KB C stack).
(define *wl-text* "")
(define *wl-n* 0)
(define *wl-i* 0)
(define *wl-start* 0)

(define (world-load-text! text)
  (set! *world-npcs* '())
  (set! *world-props* '())
  (set! *wl-text* text)
  (set! *wl-n* (string-length text))
  ; Bound work: skip pathological files (> 64KB)
  (if (> *wl-n* 65536)
      (begin (set! *world-ok* #f) #f)
    (begin
      (set! *wl-i* 0)
      (set! *wl-start* 0)
      (while (lambda () (< *wl-i* *wl-n*))
             (lambda ()
               (if (string=? (substring *wl-text* *wl-i* (+ *wl-i* 1)) "\n")
                   (begin
                     (if (> *wl-i* *wl-start*)
                         (world-apply-line!
                           (substring *wl-text* *wl-start* *wl-i*))
                       #t)
                     (set! *wl-i* (+ *wl-i* 1))
                     (set! *wl-start* *wl-i*))
                 (set! *wl-i* (+ *wl-i* 1)))))
      (if (< *wl-start* *wl-n*)
          (world-apply-line! (substring *wl-text* *wl-start* *wl-n*))
        #t)
      (set! *world-ok* #t)
      #t)))

(define (world-load! path)
  (set! *world-path* path)
  (try
    (begin
      ; Clear without full world-reset! (reset builds a huge default cast first)
      (set! *world-npcs* '())
      (set! *world-props* '())
      (set! *world-theme* "Meadow")
      (if (file-exists? path)
          (begin
            (world-load-text! (read-file path))
            (if (= (length *world-npcs*) 0)
                (world-reset!)
              #t)
            #t)
        (begin (world-reset!) #f)))
    (catch (e)
      (begin (world-reset!) #f))))

; Pure Aura worldgen (lib/worldgen-engine). Offline always available.
(define (world-generate! cols rows)
  (try
    (begin
      (worldgen-run! cols rows *world-path* #f)
      (world-load! *world-path*)
      #t)
    (catch (e)
      (begin (world-reset!) #f))))

(define (world-generate-offline! cols rows)
  (try
    (begin
      (worldgen-run! cols rows *world-path* #t)
      (world-load! *world-path*)
      #t)
    (catch (e) (begin (world-reset!) #f))))

; ── Drawing ──
;
; PERF: full per-cell Scheme color math is too slow (125x30 ≈ 4k eval_flat
; calls/frame → unresponsive keys). Strategy:
;   1) solid tui:clear with sky
;   2) fill floor as a few solid rows (same color)
;   3) sparse decorations (grid lines / stars / rain / grass) only
; Host (while) still used where loops would be long.

(define (world-px col row top bot)
  (tui:pixel col row top bot)
  #t)

(define *bg-i* 0)
(define *bg-w* 80)
(define *bg-y0* 3)
(define *bg-y1* 20)
(define *bg-total* 0)
(define *bg-floor-y* 18)
(define *bg-frame* 0)
(define *bg-rows* 16)
(define *bg-x* 0)
(define *bg-y* 0)
(define *bg-c* 0)
(define *bg-c2* 0)

; Fill one horizontal run [x0,x1) at row y with solid color (fast).
(define (bg-hfill! x0 x1 y c)
  (set! *bg-x* x0)
  (set! *bg-y* y)
  (set! *bg-c* c)
  (while (lambda () (< *bg-x* x1))
         (lambda ()
           (world-px *bg-x* *bg-y* *bg-c* *bg-c*)
           (set! *bg-x* (+ *bg-x* 1)))))

; Fill rectangular band y0..y1-1, full width.
(define (bg-vband! w y0 y1 c)
  (set! *bg-y* y0)
  (set! *bg-c* c)
  (set! *bg-w* w)
  (while (lambda () (< *bg-y* y1))
         (lambda ()
           (bg-hfill! 0 *bg-w* *bg-y* *bg-c*)
           (set! *bg-y* (+ *bg-y* 1)))))

; Vertical line every step cols (cyber/grid).
(define (bg-vlines! w y0 y1 step c)
  (set! *bg-x* 0)
  (set! *bg-c* c)
  (while (lambda () (< *bg-x* w))
         (lambda ()
           (set! *bg-y* y0)
           (while (lambda () (< *bg-y* y1))
                  (lambda ()
                    (world-px *bg-x* *bg-y* *bg-c* *bg-c*)
                    (set! *bg-y* (+ *bg-y* 1))))
           (set! *bg-x* (+ *bg-x* step)))))

; Horizontal line every step rows.
(define (bg-hlines! w y0 y1 step c)
  (set! *bg-y* y0)
  (set! *bg-c* c)
  (while (lambda () (< *bg-y* y1))
         (lambda ()
           (bg-hfill! 0 w *bg-y* *bg-c*)
           (set! *bg-y* (+ *bg-y* step)))))

; Sparse stars (~16) — not per-cell hash.
(define (bg-draw-stars! w y0 fy frame)
  (let ((c *w-star*)
        (sky *w-sky*))
    ; Fixed offsets — twinkle by skipping some frames
    (if (= (modulo frame 2) 0)
        (begin
          (world-px (modulo 5 w) (+ y0 1) c sky)
          (world-px (modulo 18 w) (+ y0 2) c sky)
          (world-px (modulo 35 w) (+ y0 1) c sky)
          (world-px (modulo 52 w) (+ y0 3) c sky)
          (world-px (modulo 70 w) (+ y0 1) c sky)
          (world-px (modulo 88 w) (+ y0 2) c sky)
          (world-px (modulo 105 w) (+ y0 1) c sky)
          (world-px (modulo 12 w) (+ y0 4) c sky))
      (begin
        (world-px (modulo 9 w) (+ y0 2) c sky)
        (world-px (modulo 28 w) (+ y0 1) c sky)
        (world-px (modulo 44 w) (+ y0 3) c sky)
        (world-px (modulo 61 w) (+ y0 2) c sky)
        (world-px (modulo 77 w) (+ y0 1) c sky)
        (world-px (modulo 96 w) (+ y0 2) c sky)
        (world-px (modulo 22 w) (+ y0 3) c sky)
        (world-px (modulo 55 w) (+ y0 4) c sky)))
    #t))

; Grass / flower dots on floor rows. step from *bg-dot-step*; accent for petals.
(define (bg-draw-ground-dots! w fy y1 frame)
  (let ((step (if (< *bg-dot-step* 1) 3 *bg-dot-step*))
        (petal *w-accent*)
        (grass (world-rgb 80 160 70)))
    (set! *bg-y* fy)
    (while (lambda () (< *bg-y* y1))
           (lambda ()
             (set! *bg-x* (modulo frame step))
             (while (lambda () (< *bg-x* w))
                    (lambda ()
                      (let ((n (modulo (+ (* *bg-x* 17) (* *bg-y* 31)) 11)))
                        (if (= n 0)
                            (world-px *bg-x* *bg-y* grass *w-floor2*)
                          (if (= n 1)
                              (world-px *bg-x* *bg-y* petal *w-star*)
                            #t)))
                      (set! *bg-x* (+ *bg-x* step))))
             (set! *bg-y* (+ *bg-y* 1))))))

; Dense petal scatter (snow/cherry) using accent color.
(define (bg-draw-petals! w y0 y1 frame)
  (let ((step (if (< *bg-dot-step* 1) 2 *bg-dot-step*))
        (c *w-accent*)
        (c2 *w-star*))
    (set! *bg-y* y0)
    (while (lambda () (< *bg-y* y1))
           (lambda ()
             (set! *bg-x* (modulo (+ frame *bg-y*) step))
             (while (lambda () (< *bg-x* w))
                    (lambda ()
                      (if (= (modulo (+ *bg-x* (* *bg-y* 3) frame) 7) 0)
                          (world-px *bg-x* *bg-y* c c2)
                        #t)
                      (set! *bg-x* (+ *bg-x* step))))
             (set! *bg-y* (+ *bg-y* 1))))))

; Ocean wave band: only 2 rows, cheap x pattern.
(define (bg-draw-waves! w y frame)
  (set! *bg-x* 0)
  (while (lambda () (< *bg-x* w))
         (lambda ()
           (let ((wave (modulo (+ *bg-x* (quotient frame 2)) 5)))
             (world-px *bg-x* y
                       (world-rgb (+ 20 (* wave 10)) (+ 90 (* wave 8)) 180)
                       (world-rgb 20 70 150))
             (if (< (+ y 1) *bg-y1*)
                 (world-px *bg-x* (+ y 1)
                           (world-rgb 30 100 170) (world-rgb 20 80 150))
               #t))
           (set! *bg-x* (+ *bg-x* 1)))))

; City skyline: every 2nd column, short towers only (cheap).
(define (bg-draw-skyline! w fy frame)
  (set! *bg-x* 0)
  (set! *bg-c* (world-rgb 35 38 55))
  (set! *bg-c2* (world-rgb 255 220 80))
  (while (lambda () (< *bg-x* w))
         (lambda ()
           (let* ((bh (+ 2 (modulo (+ (* *bg-x* 5) 3) 4)))
                  (y0 (- fy bh)))
             (set! *bg-y* y0)
             (while (lambda () (< *bg-y* fy))
                    (lambda ()
                      (if (and (= (modulo *bg-y* 2) 0)
                               (= (modulo (+ *bg-x* frame) 4) 0))
                          (world-px *bg-x* *bg-y* *bg-c2* *bg-c*)
                        (world-px *bg-x* *bg-y* *bg-c* *bg-c*))
                      (set! *bg-y* (+ *bg-y* 1)))))
           (set! *bg-x* (+ *bg-x* 2)))))

; Matrix rain — drop count from *bg-rain-n* (param / layers / LLM).
(define (bg-rain-init! w y0 y1)
  (let* ((want (if (and (number? *bg-rain-n*) (> *bg-rain-n* 0))
                   *bg-rain-n* 12))
         (n (if (< w 50)
                (if (> want 10) 10 want)
              (if (> want 24) 24 want))))
    (let loop ((i 0) (acc '()))
      (if (>= i n)
          (begin (set! *bg-rain* acc) (set! *bg-rain-ready* #t) #t)
        (loop (+ i 1)
              (cons (list (modulo (* i 11) w)
                          (+ y0 (modulo (* i 5)
                                       (if (<= (- y1 y0) 1) 1 (- y1 y0))))
                          (+ 1 (modulo i 2))
                          (+ 33 (modulo (* i 17) 90)))
                    acc))))))

(define (bg-rain-tick! w y0 y1)
  (set! *bg-rain*
    (let loop ((ds *bg-rain*) (acc '()))
      (if (null? ds)
          (reverse acc)
        (let* ((d (car ds))
               (x (car d))
               (y (car (cdr d)))
               (sp (car (cdr (cdr d))))
               (seed (car (cdr (cdr (cdr d)))))
               (ny (+ y sp)))
          (loop (cdr ds)
                (cons (list x
                            (if (>= ny y1) y0 ny)
                            sp
                            (modulo (+ seed 11) 90))
                      acc)))))))

(define (bg-rain-draw! frame)
  (let ((palette "01#$%&*+=<>/\\|")
        (plen 14)
        (g1 *w-accent*)
        (g0 *w-star*)
        (bgc *w-sky*))
    (let loop ((ds *bg-rain*))
      (if (null? ds) #t
        (let* ((d (car ds))
               (x (car d))
               (y (car (cdr d)))
               (seed (car (cdr (cdr (cdr d)))))
               (pi (modulo (+ seed frame) plen))
               (ch (substring palette pi (+ pi 1)))
               (bright (= (modulo (+ x y frame) 4) 0)))
          (tui:cell x y ch (if bright g1 g0) bgc 0)
          (if (> y *bg-y0*)
              (tui:cell x (- y 1) ch g0 bgc 0)
            #t)
          (loop (cdr ds)))))))

; Palette-driven base (LLM sky:/floor: always visible — Slice A).
(define (bg-base-sky) *w-sky*)
(define (bg-base-floor) *w-floor*)

; Draw one recipe layer (unknown kinds ignored).
(define (bg-draw-layer! L w y0 y1 floor-y fr)
  (let ((k (if (and (pair? L) (string? (car L))) (car L) "")))
    (cond
      ((string=? k "rain")
       (begin
         (if (not *bg-rain-ready*)
             (bg-rain-init! w y0 floor-y)
           #t)
         (bg-rain-tick! w y0 floor-y)
         (bg-rain-draw! fr)))
      ((string=? k "grid")
       (let ((sx (if (and (pair? (cdr L)) (string? (car (cdr L))))
                     (world-num-or (car (cdr L)) *bg-grid-x*)
                   *bg-grid-x*))
             (sy (if (and (pair? (cdr L)) (pair? (cdr (cdr L)))
                          (string? (car (cdr (cdr L)))))
                     (world-num-or (car (cdr (cdr L))) *bg-grid-y*)
                   *bg-grid-y*)))
         (bg-vlines! w y0 floor-y (if (< sx 2) 8 sx) *w-accent*)
         (bg-hlines! w y0 floor-y (if (< sy 2) 4 sy) *w-star*)))
      ((string=? k "stars")
       (bg-draw-stars! w y0 floor-y fr))
      ((string=? k "waves")
       (bg-draw-waves! w (- floor-y 2) fr))
      ((string=? k "skyline")
       (bg-draw-skyline! w floor-y fr))
      ((string=? k "dots")
       (bg-draw-ground-dots! w floor-y y1 fr))
      ((or (string=? k "petals") (string=? k "snow") (string=? k "cherry"))
       (bg-draw-petals! w y0 y1 fr))
      (else #t))))

; Caller should (tui:clear (bg-base-sky) ...) first — sky is free in C++.
; Floor band + sparse recipe layers (keeps play loop responsive).
(define (world-draw-bg! w h y0 y1 frame)
  (let ((floor-y (- y1 2))
        (rows (- y1 y0))
        (fr (if (number? frame) frame 0)))
    (if (or (<= w 0) (<= rows 0))
        #t
      (begin
        (set! *bg-w* w)
        (set! *bg-y0* y0)
        (set! *bg-y1* y1)
        (set! *bg-floor-y* floor-y)
        (set! *bg-rows* rows)
        (set! *bg-frame* fr)
        ; Floor only (2 rows)
        (bg-vband! w floor-y y1 (bg-base-floor))
        ; Ensure we have a recipe
        (if (null? *bg-layers*)
            (world-load-default-layers!)
          #t)
        ; Interpret layer list (O(layers * sparse work))
        (let loop ((xs *bg-layers*))
          (if (null? xs) #t
            (begin
              (bg-draw-layer! (car xs) w y0 y1 floor-y fr)
              (loop (cdr xs)))))
        (world-draw-props!)
        #t))))

(define (world-draw-props!)
  (let loop ((xs *world-props*))
    (if (null? xs) #t
      (begin
        (let* ((p (car xs))
               (kind (car p))
               (x (car (cdr p)))
               (y (car (cdr (cdr p))))
               (sprite-name (prop-sprite-name p)))
          (cond
            (sprite-name
             (let ((sprite (world-sprite-get sprite-name)))
               (if sprite
                   (world-sprite-draw! sprite x y)
                   ; sprite not found, fall back to kind dispatch
                   (world-draw-prop-kind! kind x y))))
            (else (world-draw-prop-kind! kind x y))))
        (loop (cdr xs))))))

(define (world-draw-prop-kind! kind x y)
  (cond
    ((string=? kind "tree") (world-draw-tree! x y))
    ((string=? kind "flower") (world-draw-flower! x y))
    ((string=? kind "crate") (world-draw-crate! x y))
    ((string=? kind "wall") (world-draw-wall! x y))
    ((string=? kind "bush") (world-draw-bush! x y))
    (else (world-draw-rock! x y))))

(define (world-draw-tree! x y)
  (let ((green (world-rgb 40 140 60))
        (green2 (world-rgb 30 110 45))
        (bark (world-rgb 110 70 40)))
    (world-px x (- y 2) green green2)
    (world-px (+ x 1) (- y 2) green green)
    (world-px (- x 1) (- y 1) green green2)
    (world-px x (- y 1) green green)
    (world-px (+ x 1) (- y 1) green green2)
    (world-px (+ x 2) (- y 1) green green)
    (world-px x y bark bark)
    (world-px (+ x 1) y bark bark)
    #t))

(define (world-draw-flower! x y)
  (let ((pink (world-rgb 255 120 160))
        (yel (world-rgb 255 220 80))
        (stem (world-rgb 50 160 70)))
    (world-px x (- y 1) pink yel)
    (world-px x y stem stem)
    #t))

(define (world-draw-rock! x y)
  (let ((g (world-rgb 120 120 130))
        (g2 (world-rgb 90 90 100)))
    (world-px x y g g2)
    (world-px (+ x 1) y g2 g)
    #t))

; Cover / 掩体: crate, wall, bush (for tank-style peeking)
(define (world-draw-crate! x y)
  (let ((wood (world-rgb 160 100 50))
        (wood2 (world-rgb 120 70 30))
        (nail (world-rgb 200 200 180)))
    (world-px x (- y 1) wood wood2)
    (world-px (+ x 1) (- y 1) wood2 wood)
    (world-px x y wood2 wood)
    (world-px (+ x 1) y wood wood2)
    (world-px x (- y 1) nail wood)
    #t))

(define (world-draw-wall! x y)
  (let ((br (world-rgb 140 90 70))
        (br2 (world-rgb 100 60 50))
        (mort (world-rgb 80 80 80)))
    (world-px x (- y 2) br br2)
    (world-px (+ x 1) (- y 2) br2 br)
    (world-px x (- y 1) br2 mort)
    (world-px (+ x 1) (- y 1) mort br)
    (world-px x y br br2)
    (world-px (+ x 1) y br2 br)
    #t))

(define (world-draw-bush! x y)
  (let ((g (world-rgb 40 140 50))
        (g2 (world-rgb 20 100 35)))
    (world-px x (- y 1) g g2)
    (world-px (+ x 1) (- y 1) g2 g)
    (world-px (- x 1) y g g2)
    (world-px x y g2 g)
    (world-px (+ x 1) y g g)
    #t))

; Vertical bounce: -1 / 0 / 1 cycle (was always 0 — looked frozen).
(define (npc-bob frame i)
  (let ((ph (modulo (+ frame (* i 3)) 6)))
    (cond
      ((or (= ph 0) (= ph 3)) 0)
      ((or (= ph 1) (= ph 2)) -1)
      (else 1))))

; Horizontal wiggle while idle-drawing (before wander mutates base x).
(define (npc-wiggle frame i)
  (let ((ph (modulo (+ frame (* i 5)) 12)))
    (cond
      ((< ph 3) 0)
      ((< ph 6) 1)
      ((< ph 9) 0)
      (else -1))))

; Palette by name length so NPCs look different.
(define (npc-fur-colors kind name)
  (let ((h (modulo (* (string-length name) 37) 5)))
    (if (string=? kind "decor")
        (cons (world-rgb 180 180 200) (world-rgb 140 140 160))
      (cond
        ((= h 0) (cons (world-rgb 255 200 120) (world-rgb 240 160 90)))
        ((= h 1) (cons (world-rgb 255 160 180) (world-rgb 230 120 150)))
        ((= h 2) (cons (world-rgb 160 220 255) (world-rgb 100 180 230)))
        ((= h 3) (cons (world-rgb 180 255 160) (world-rgb 120 210 100)))
        (else (cons (world-rgb 255 230 140) (world-rgb 230 190 80)))))))

; Draw NPCs with bob + wiggle + blink + phase pose.
; Dynamic sprite (LLM-defined) wins; falls through to hardcode path.
(define (world-draw-npcs! frame)
  (let loop ((xs *world-npcs*) (i 0))
    (if (null? xs) #t
      (begin
        (let* ((n (car xs))
               (name (car n))
               (bx (car (cdr n)))
               (by (car (cdr (cdr n))))
               (kind (car (cdr (cdr (cdr n)))))
               (bob (npc-bob frame i))
               (wig (npc-wiggle frame i))
               (x (+ bx wig))
               (y (+ by bob))
               (blink (= (modulo (+ frame (* i 7)) 20) 0)))
          (world-draw-npc-sprite! x y kind name frame i blink n)
          (draw-text x (+ y 2) name (world-rgb 200 220 255) 0))
        (loop (cdr xs) (+ i 1))))))

(define (world-draw-npc-sprite! x y kind name frame i blink n)
  ; Dynamic sprite path (LLM-defined). Static, no bob/wig on the sprite
  ; itself; the surrounding draw-npcs! already applied bob/wig.
  (let ((sprite-name (npc-sprite-name n)))
    (if sprite-name
        (let ((sprite (world-sprite-get sprite-name)))
          (if sprite
              (begin (world-sprite-draw! sprite x y) #t)
              (world-draw-npc-sprite-hardcode! x y kind name frame i blink)))
        (world-draw-npc-sprite-hardcode! x y kind name frame i blink))))

(define (world-draw-npc-sprite-hardcode! x y kind name frame i blink)
  (let* ((cols (npc-fur-colors kind name))
         (fur (car cols))
         (fur2 (cdr cols))
         (eye (if blink (world-rgb 40 40 50) (world-rgb 20 20 30)))
         (eye2 (if blink fur (world-rgb 255 255 255)))
         (phase (modulo (+ frame (* i 2)) 4)))
    ; body
    (world-px x y fur fur2)
    (world-px (+ x 1) y fur fur)
    (world-px (+ x 2) y fur2 fur)
    (world-px x (+ y 1) fur2 fur)
    ; face / eyes (blink closes)
    (world-px (+ x 1) (+ y 1) eye eye2)
    (world-px (+ x 2) (+ y 1) fur fur2)
    ; leg / hop pose — alternate feet
    (if (or (= phase 0) (= phase 1))
        (world-px x (+ y 2) fur2 fur)
      (world-px (+ x 2) (+ y 2) fur fur2))
    ; ear / hat bobble on even phase
    (if (or (= phase 0) (= phase 2))
        (world-px (+ x 1) (- y 1) fur2 fur)
      (world-px x (- y 1) fur fur2))
    #t))

; Pseudo-random 0..n-1 from frame + seed (no RNG primitive needed).
(define (world-prng frame seed n)
  (if (<= n 0) 0
    (modulo (+ (* frame 1103515245) (* seed 12345) 12345) n)))

; Random roam: each NPC picks a direction bit-pattern and steps on its own cadence.
(define (world-tick-npcs! frame cols y0 y1)
  (if (not (= (modulo frame 3) 0))
      #t
    (begin
      (set! *world-npcs*
        (let loop ((xs *world-npcs*) (i 0) (acc '()))
          (if (null? xs)
              (reverse acc)
            (let* ((n (car xs))
                   (name (car n))
                   (x (car (cdr n)))
                   (y (car (cdr (cdr n))))
                   (kind (car (cdr (cdr (cdr n)))))
                   (speech (car (cdr (cdr (cdr (cdr n))))))
                   ; personal tick: some NPCs move more often
                   (cad (+ 1 (world-prng i 7 3)))
                   (move? (= (modulo frame (* 3 cad)) 0))
                   (roll (world-prng frame (+ i 3) 8))
                   ; 0-3 step dirs, 4-7 idle (more idle = natural)
                   (dx (if (not move?) 0
                         (cond ((= roll 0) -1) ((= roll 1) 1) (else 0))))
                   (dy (if (not move?) 0
                         (cond ((= roll 2) -1) ((= roll 3) 1)
                               ; occasional diagonal-ish extra
                               ((= roll 4) (if (= (world-prng frame i 2) 0) -1 1))
                               (else 0))))
                   (nx (let ((v (+ x dx)))
                         (if (< v 2) 2
                           (if (> v (- cols 5)) (- cols 5) v))))
                   (ny (let ((v (+ y dy)))
                         (if (< v (+ y0 1)) (+ y0 1)
                           (if (> v (- y1 4)) (- y1 4) v)))))
              (loop (cdr xs) (+ i 1)
                    (cons (list name nx ny kind speech (npc-sprite-name n)) acc))))))
      #t)))

; Nearest friend NPC speech within manhattan dist 6
(define (world-nearest-speech px py)
  (let loop ((xs *world-npcs*) (best #f) (best-d 999))
    (if (null? xs)
        best
      (let* ((n (car xs))
             (x (car (cdr n)))
             (y (car (cdr (cdr n))))
             (kind (car (cdr (cdr (cdr n)))))
             ; Prefer living on-talk behavior when entity.aura is loaded.
             (speech
               (try
                 (npc-react-speech (npc-normalize n) "on-talk")
                 (catch (e) (car (cdr (cdr (cdr (cdr n))))))))
             (dx (if (> px x) (- px x) (- x px)))
             (dy (if (> py y) (- py y) (- y py)))
             (d (+ dx dy)))
        (if (and (string=? kind "friend")
                 (< d best-d)
                 (<= d 6)
                 (string? speech)
                 (> (string-length speech) 0))
            (loop (cdr xs) speech d)
          (loop (cdr xs) best best-d))))))

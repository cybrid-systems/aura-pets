; lib/nl-engine.aura — natural-language → ops file in pure Aura.
;
; (nl-engine-run! text cols rows out-path offline?) → #t/#f
; Offline keyword heuristics + online MiniMax via llm-client.
; Load: llm-client first.

(define *nl-sys*
  (string-append
    "You are the live director of a kids terminal pet game (Aura eDSL).\n"
    "Convert player text into ONLY plain apply-lines (no markdown):\n"
    "say:<reply max 40>\ntheme:<name>\n"
    "bg:<meadow|cyber|matrix|stars|city|ocean|grid|sunset>\n"
    "sky:r,g,b\nsky2:r,g,b\nfloor:r,g,b\nfloor2:r,g,b\nstar:r,g,b\n"
    "npc_clear:\nnpc:<Name>|<x>|<y>|<friend|decor>|<speech>[|<sprite-name>]\n"
    "prop_clear:\nprop:<tree|flower|rock|crate|wall|bush>|<x>|<y>[|<sprite-name>]\n"
    "sprite:<name>|<w>|<h>|<r>,<g>,<b>|<r>,<g>,<b>|...   (define a custom sprite, max 16x12)\n"
    "teach:<feed|play|sleep|evolve|move|idle>|<speech>\n"
    "target:<npc:Name|npc#id|npc@near|npc:kind=friend|pet:self>\n"
    "set:<hp|atk|speech|ai|kind|x|y>|<value>\n"
    "add:<hp|atk>|<delta>\n"
    "trait:<fierce|clingy|lazy|curious|chatty>|<delta -3..3>\n"
    "ai:<coward|hunter|guard|wander|friend>\n"
    "teach_npc:<idle|on-hit|on-talk>|<speech>\n"
    "ability:<taunt|shield|dash|heal>|<on|off>[|<param>]\n"
    "snapshot:\ndiff:\n"
    "aura:commit\nhelp:\n"
    "To edit an NPC (query then mutate fields), emit target: then patches.\n"
    "Example — make nearby Bunny fiercer with more HP:\n"
    "  say:Bunny evolved!\n  target:npc:Bunny\n  snapshot:\n"
    "  set:hp|20\n  trait:fierce|3\n  ai:hunter\n"
    "  teach_npc:on-hit|Don't touch me!\n  diff:\n"
    "Background: cyber/matrix = neon grid + matrix rain (cyber cat).\n"
    "stars=night, ocean=beach, city=skyline, sunset=warm sky, meadow=park.\n"
    "When user asks for cyber/neon/matrix/赛博, emit bg:cyber + dark sky colors.\n"
    "Prefer 4-6 npcs and 6-10 props (max 6 npcs / 12 props). "
    "Kid-safe. ASCII names. x in [2,COLS-4] y in [4,ROWS-7].\n"
    "To make a custom creature (dragon/robot/blob/whatever), first emit "
    "a sprite op with w*h cells of r,g,b triples, then add npc referencing "
    "the sprite by name (6th field). Example:\n"
    "  sprite:blob|3|3|255,0,0|0,255,0|0,0,255|255,255,0|255,0,255|255,128,0|0,255,255|255,255,255|0,0,0\n"
    "  npc:Blob|15|8|friend|Hi!|blob\n"
    "Each cell is one r,g,b triple; rows left-to-right, top-to-bottom."))

; ── Offline heuristics ──
(define (nl-has? s sub)
  (let ((n (string-length s))
        (m (string-length sub)))
    (if (> m n) #f
      (let loop ((i 0))
        (if (> (+ i m) n) #f
          (if (string=? (substring s i (+ i m)) sub) #t
            (loop (+ i 1))))))))

(define (nl-offline-ops text cols rows)
  (let* ((t text)
         (floor-y (if (< (- rows 6) 8) 8 (- rows 6)))
         (snow (or (nl-has? t "snow") (nl-has? t "冬") (nl-has? t "雪")
                   (nl-has? t "ice") (nl-has? t "cold")))
         (beach (or (nl-has? t "beach") (nl-has? t "海") (nl-has? t "sand")))
         (night (or (nl-has? t "night") (nl-has? t "夜") (nl-has? t "star")))
         (cyber (or (nl-has? t "cyber") (nl-has? t "Cyber")
                    (nl-has? t "matrix") (nl-has? t "neon")
                    (nl-has? t "赛博") (nl-has? t "矩阵")
                    (nl-has? t "rain") (nl-has? t "黑客")))
         (city (or (nl-has? t "city") (nl-has? t "城") (nl-has? t "urban")))
         (bg-only (or (nl-has? t "bg") (nl-has? t "background")
                      (nl-has? t "背景") (nl-has? t "/bg")))
         (want-world (or snow beach night cyber city
                         (nl-has? t "world") (nl-has? t "park")
                         (nl-has? t "scene") (nl-has? t "npc")
                         (nl-has? t "背景") (nl-has? t "公园")
                         (nl-has? t "make") (nl-has? t "create")
                         bg-only
                         (> (string-length t) 6))))
    (if (or (nl-has? t "teach") (nl-has? t "教"))
        (string-append
          "say:Learned feed!\n"
          "teach:feed|Yum!\n"
          "aura:commit\n")
      ; Background-only prompts: switch style + palette without full regen
      (if (and bg-only (or cyber night beach city snow) (not (nl-has? t "npc")))
          (cond
            (cyber
             (string-append
               "say:Cyber rain ON!\n"
               "theme:Cyber Cat City\n"
               "bg:cyber\n"
               "sky:0,8,18\nsky2:0,20,35\n"
               "floor:10,15,30\nfloor2:5,10,20\n"
               "star:0,255,120\n"))
            (night
             (string-append
               "say:Starry night!\n"
               "theme:Starry Park\n"
               "bg:stars\n"
               "sky:4,6,24\nsky2:12,10,40\n"
               "floor:18,20,40\nfloor2:10,12,28\n"
               "star:230,235,255\n"))
            (beach
             (string-append
               "say:Ocean waves!\n"
               "theme:Sunny Beach\n"
               "bg:ocean\n"
               "sky:80,160,230\nsky2:180,220,255\n"
               "floor:200,180,120\nfloor2:170,150,100\n"
               "star:255,255,200\n"))
            (city
             (string-append
               "say:City lights!\n"
               "theme:Neon City\n"
               "bg:city\n"
               "sky:20,25,50\nsky2:60,40,70\n"
               "floor:30,30,40\nfloor2:20,20,28\n"
               "star:255,220,80\n"))
            (else
             (string-append
               "say:Snow soft!\n"
               "theme:Snowy Meadow\n"
               "bg:meadow\n"
               "sky:180,200,230\nsky2:220,230,245\n"
               "floor:240,245,255\nfloor2:200,210,230\n"
               "star:255,255,255\n")))
        (if want-world
            (string-append
              (cond
                (cyber
                 (string-append
                   "say:Cyber park online!\n"
                   "theme:Cyber Cat City\n"
                   "bg:cyber\n"
                   "sky:0,8,18\nsky2:0,20,35\n"
                   "floor:10,15,30\nfloor2:5,10,20\n"
                   "star:0,255,120\n"))
                (snow "say:Snow day!\ntheme:Snowy Meadow\nbg:meadow\n")
                (beach "say:Beach day!\ntheme:Sunny Beach\nbg:ocean\n")
                (night "say:Night park!\ntheme:Starry Park\nbg:stars\n")
                (city "say:City walk!\ntheme:Neon City\nbg:city\n")
                (else "say:New park ready!\ntheme:Sunset Meadow\nbg:sunset\n"))
              (worldgen-offline cols rows))
          (string-append
            "say:Try cyber rain / starry night / /bg cyber\n"
            "help:\n"))))))

(define (nl-engine-run! text cols rows out-path offline?)
  (let ((force-off
          (or offline?
              (let ((e (try (getenv "AURA_PETS_NL_OFFLINE") (catch (e) #f))))
                (and e (string? e) (> (string-length e) 0)
                     (not (string=? e "0")))))))
    (let ((ops
            (if force-off
                (nl-offline-ops text cols rows)
              (let* ((ctx (try (if (file-exists? "/tmp/aura-pets-nl-ctx.txt")
                                   (read-file "/tmp/aura-pets-nl-ctx.txt")
                                 "")
                               (catch (e) "")))
                     (user (string-append
                             "COLS=" (number->string cols)
                             " ROWS=" (number->string rows) "\n"
                             "Context:\n" ctx "\n"
                             "Player said:\n" text))
                     (raw (llm-chat *nl-sys* user)))
                (if raw
                    ; keep raw lines; world/apply will cap
                    (string-append raw "\n")
                  (nl-offline-ops text cols rows))))))
      (try
        (begin
          (write-file out-path ops)
          (try
            (shell (string-append
                     "echo nl-engine-aura:wrote " out-path
                     (if force-off " offline" " live")
                     " >>/tmp/aura-pets-debug.log"))
            (catch (e) #f))
          #t)
        (catch (e) #f)))))

; lib/worldgen-engine.aura — world line-file generation in pure Aura.
;
; (worldgen-offline cols rows) → text
; (worldgen-run! cols rows out-path offline?) → #t/#f  writes file
;
; Online path: llm-client → MiniMax → best-effort keep lines (sanitize light).

; Depends: llm-client (for online), write-file

(define *wg-system*
  (string-append
    "You design cute kid-safe virtual pet game worlds for a terminal pixel game.\n"
    "Reply with ONLY plain text lines (no markdown):\n"
    "theme:<name>\n"
    "bg:<meadow|cyber|matrix|stars|city|ocean|grid|sunset>\n"
    "sky:r,g,b\nsky2:r,g,b\nfloor:r,g,b\nfloor2:r,g,b\nstar:r,g,b\n"
    "npc:<Name>|<x>|<y>|<friend|decor>|<speech>\n"
    "prop:<tree|flower|rock|crate|wall|bush>|<x>|<y>\n"
    "Rules: 4-6 npc (max 6), 6-10 prop (max 12). ASCII names. "
    "bg cyber = neon grid + matrix rain (cyber cat). "
    "x in [2,COLS-4], y in [4,ROWS-7]. Kid-safe."))

(define (worldgen-offline cols rows)
  (let* ((floor-y (if (< (- rows 6) 8) 8 (- rows 6)))
         (names
           (list
             (list "Bunny" "friend" "Hi! Want to play?")
             (list "Bird" "friend" "Chirp! Nice day!")
             (list "Frog" "friend" "Ribbit~")
             (list "Fox" "friend" "Sly hi!")
             (list "Owl" "friend" "Hoo there!")
             (list "Pip" "decor" "Spark!")))
         (props
           (list "tree" "tree" "flower" "flower" "crate" "wall"
                 "bush" "rock" "crate" "bush"))
         (x-span (if (< (- cols 8) 8) 8 (- cols 8)))
         (y-span (if (< (- floor-y 6) 4) 4 (- floor-y 6)))
         (s0 (string-append
               "theme:Sunset Meadow\n"
               "bg:sunset\n"
               "sky:40,30,90\nsky2:90,50,70\n"
               "floor:55,110,65\nfloor2:40,90,50\nstar:255,220,160\n")))
    (let loop ((xs names) (i 0) (acc s0))
      (if (null? xs)
          (let loop2 ((ps props) (j 0) (acc2 acc))
            (if (null? ps)
                acc2
              (let ((x (+ 3 (modulo (* j 7) (if (< (- cols 6) 6) 6 (- cols 6)))))
                    (y (if (< (- floor-y (modulo j 4)) 5)
                           5
                         (- floor-y (modulo j 4)))))
                (loop2 (cdr ps) (+ j 1)
                       (string-append acc2 "prop:" (car ps) "|"
                                      (number->string x) "|"
                                      (number->string y) "\n")))))
        (let* ((n (car xs))
               (x (+ 4 (modulo (* i 5) x-span)))
               (y (+ 5 (modulo (* i 3) y-span))))
          (loop (cdr xs) (+ i 1)
                (string-append acc
                  "npc:" (car n) "|" (number->string x) "|"
                  (number->string y) "|" (car (cdr n)) "|"
                  (car (cdr (cdr n))) "\n")))))))

; Light keep: only lines that look like world format; drop rest.
(define (worldgen-keep-line? line)
  (let ((n (string-length line)))
    (if (= n 0) #f
      (or (and (>= n 6) (string=? (substring line 0 6) "theme:"))
          (and (>= n 3) (string=? (substring line 0 3) "bg:"))
          (and (>= n 4) (string=? (substring line 0 4) "sky:"))
          (and (>= n 5) (string=? (substring line 0 5) "sky2:"))
          (and (>= n 6) (string=? (substring line 0 6) "floor:"))
          (and (>= n 7) (string=? (substring line 0 7) "floor2:"))
          (and (>= n 5) (string=? (substring line 0 5) "star:"))
          (and (>= n 4) (string=? (substring line 0 4) "npc:"))
          (and (>= n 5) (string=? (substring line 0 5) "prop:"))
          (and (>= n 7) (string=? (substring line 0 7) "sprite:"))))))

; Host while scan — named-let over LLM-sized text SIGSEGVs (no TCO).
(define *wg-text* "")
(define *wg-n* 0)
(define *wg-i* 0)
(define *wg-start* 0)
(define *wg-acc* "")
(define *wg-nn* 0)
(define *wg-np* 0)
(define *wg-max-npc* 6)
(define *wg-max-prop* 12)

(define (worldgen-filter-text text cols rows)
  (set! *wg-text* text)
  (set! *wg-n* (string-length text))
  (set! *wg-i* 0)
  (set! *wg-start* 0)
  (set! *wg-acc* (substring "x" 0 0))
  (set! *wg-nn* 0)
  (set! *wg-np* 0)
  (while (lambda () (<= *wg-i* *wg-n*))
         (lambda ()
           (if (or (= *wg-i* *wg-n*)
                   (string=? (substring *wg-text* *wg-i* (+ *wg-i* 1)) "\n"))
               (begin
                 (let ((line (if (>= *wg-start* *wg-i*)
                                 (substring "x" 0 0)
                               (substring *wg-text* *wg-start* *wg-i*))))
                   (if (worldgen-keep-line? line)
                       (let ((is-npc (and (>= (string-length line) 4)
                                          (string=? (substring line 0 4) "npc:")))
                             (is-prop (and (>= (string-length line) 5)
                                           (string=? (substring line 0 5) "prop:"))))
                         (if (and is-npc (>= *wg-nn* *wg-max-npc*))
                             #t
                           (if (and is-prop (>= *wg-np* *wg-max-prop*))
                               #t
                             (begin
                               (if is-npc (set! *wg-nn* (+ *wg-nn* 1)) #t)
                               (if is-prop (set! *wg-np* (+ *wg-np* 1)) #t)
                               (set! *wg-acc*
                                 (string-append *wg-acc* line "\n"))))))
                     #t))
                 (if (= *wg-i* *wg-n*)
                     (set! *wg-i* (+ *wg-n* 1))
                   (begin
                     (set! *wg-i* (+ *wg-i* 1))
                     (set! *wg-start* *wg-i*))))
             (set! *wg-i* (+ *wg-i* 1)))))
  *wg-acc*)

(define (worldgen-llm cols rows)
  (let* ((user (string-append
                 "Terminal size COLS=" (number->string cols)
                 " ROWS=" (number->string rows) ". "
                 "Create a cheerful park with about 5 animal NPCs and 8 cover props."))
         (raw (llm-chat *wg-system* user)))
    (if (not raw)
        #f
      ; Caps applied at world-add-npc!/prop load time.
      (if (< (string-length raw) 40) #f raw))))

; Write world file. offline? forces no network.
(define (worldgen-run! cols rows out-path offline?)
  (let* ((raw
           (if offline?
               (worldgen-offline cols rows)
             (let ((live (worldgen-llm cols rows)))
               (if live live (worldgen-offline cols rows)))))
         (text (worldgen-filter-text raw cols rows)))
    (try
      (begin
        (write-file out-path text)
        ; Never read-modify-write the live debug log (races with parent plog → SIGSEGV).
        (try
          (shell (string-append
                   "echo worldgen-aura:wrote " out-path
                   " >>/tmp/aura-pets-debug.log"))
          (catch (e) #f))
        #t)
      (catch (e) #f))))

; lib/pet-game.aura — kids session + care commands (uses edsl + anim).
;
; Load order: lifecycle → edsl → anim → this file.

(define *love* 0)
(define *speech* "Hi! Arrows move me. 1 2 3 care!")
(define *last-act* "idle")
(define *care-count* 0)

(define (game-reset!)
  (set! *love* 0)
  (set! *care-count* 0)
  (set! *last-act* "idle")
  (set! *speech* "Hi! Arrows move me. 1 2 3 care!")
  (edsl-reset!)
  (anim-reset!)
  #t)

(define (game-love) *love*)
(define (game-speech) *speech*)
(define (game-last-act) *last-act*)
(define (game-care-count) *care-count*)

(define (game-set-speech! s)
  (set! *speech* s)
  #t)

(define (game-add-love! n)
  (set! *love* (+ *love* n))
  (if (> *love* 9) (set! *love* 9) #t)
  *love*)

(define (game-soft-tick pet)
  (let ((h (pet-hunger pet))
        (m (pet-mood pet))
        (e (pet-energy pet)))
    (let ((nh (if (> h 2) (- h 1) h))
          (ne (if (> e 2) (- e 1) e)))
      (if (and (= nh h) (= ne e))
          pet
        (let ((u (pet-with-vitals pet nh m ne)))
          (store-put! (pet-id u) u)
          u)))))

(define (game-can-evolve? pet)
  (and (= (pet-version pet) 0)
       (>= *love* 3)
       (>= (pet-mood pet) 7)
       (>= (pet-hunger pet) 5)))

(define (game-love-stars)
  (cond
    ((<= *love* 0) "...")
    ((= *love* 1) "*..")
    ((= *love* 2) "**.")
    (else "***")))

(define (game-mood-kid p)
  (let ((m (pet-mood p)))
    (if (>= m 8) "happy"
      (if (>= m 5) "ok" "sad"))))

(define (game-apply-care pet event pet-fn anim-name)
  (let ((u (pet-fn pet))
        (delta (edsl-love-delta event)))
    (set! *care-count* (+ *care-count* 1))
    (game-add-love! delta)
    (set! *last-act* event)
    (set! *speech* (edsl-speech event))
    (anim-start! anim-name 14)
    (cons #t u)))

; Parse "teach feed Hello there" → teach feed speech
(define (game-try-teach! cmd)
  (let ((n (string-length cmd)))
    (if (and (>= n 6) (string=? (substring cmd 0 5) "teach")
             (string=? (substring cmd 5 6) " "))
        (let* ((rest (substring cmd 6 n))
               (sp (string-find-space rest)))
          (if (< sp 0)
              #f
            (let ((ev (substring rest 0 sp))
                  (msg (substring rest (+ sp 1) (string-length rest))))
              (if (or (= (string-length ev) 0) (= (string-length msg) 0))
                  #f
                (begin
                  (edsl-teach! ev msg)
                  (set! *speech* (string-append "Learned " ev "!"))
                  (set! *last-act* "teach")
                  (edsl-aura-commit!)
                  #t)))))
      #f)))

; Minimal space finder (Aura may lack string-index).
(define (string-find-space s)
  (let ((n (string-length s)))
    (let loop ((i 0))
      (if (>= i n)
          -1
        (if (string=? (substring s i (+ i 1)) " ")
            i
          (loop (+ i 1)))))))

; Returns (keep-going? . pet)
(define (game-do pet cmd)
  (cond
    ((or (string=? cmd "quit") (string=? cmd "q") (string=? cmd "exit")
         (string=? cmd "bye"))
     (set! *speech* "Bye-bye! Come back soon!")
     (set! *last-act* "bye")
     (cons #f pet))

    ((or (string=? cmd "help") (string=? cmd "?"))
     (set! *speech* "Try /help  /grow /fight /eat /back")
     (set! *last-act* "help")
     (cons #t pet))

    ((or (string=? cmd "brain") (string=? cmd "edsl"))
     (set! *speech* (edsl-show))
     (set! *last-act* "brain")
     (cons #t pet))

    ; world / gen / g — LLM (or offline) regen of bg + NPCs
    ((or (string=? cmd "world") (string=? cmd "gen") (string=? cmd "g"))
     (set! *last-act* "world")
     (set! *speech* "Making a new world...")
     (cons #t pet))

    ; talk / t — speech from nearest NPC (caller fills using world-nearest)
    ((or (string=? cmd "talk") (string=? cmd "t"))
     (set! *last-act* "talk")
     (cons #t pet))

    ((game-try-teach! cmd)
     (cons #t pet))

    ((or (string=? cmd "feed") (string=? cmd "1") (string=? cmd "f")
         (string=? cmd "eat"))
     (game-apply-care pet "feed" pet-feed "eat"))

    ((or (string=? cmd "play") (string=? cmd "2") (string=? cmd "p"))
     (game-apply-care pet "play" pet-play "play"))

    ((or (string=? cmd "sleep") (string=? cmd "3") (string=? cmd "s")
         (string=? cmd "z"))
     (game-apply-care pet "sleep" pet-sleep "sleep"))

    ((or (string=? cmd "evolve") (string=? cmd "e") (string=? cmd "grow"))
     (if (not (= (pet-version pet) 0))
         (begin
           (set! *speech* "Already grown! Keep caring.")
           (set! *last-act* "idle")
           (cons #t pet))
       (if (game-can-evolve? pet)
           (let ((u (pet-evolve pet "/tmp/brain-v2" "love")))
             (set! *last-act* "evolve")
             (set! *speech* (edsl-speech "evolve"))
             (game-add-love! (edsl-love-delta "evolve"))
             (anim-start! "evolve" 18)
             (cons #t u))
         (begin
           (set! *last-act* "idle")
           (set! *speech*
             (if (< *love* 3)
                 "Need more love! Care with 1 2 3."
               "Need happy + full tummy to grow."))
           (cons #t pet)))))

    (else
     (set! *speech* "Huh? Try 1 2 3 arrows or teach feed Hi")
     (set! *last-act* "idle")
     (cons #t pet))))

; Movement: keep silent (no per-step string-append / log). Heap churn from
; speech+log on every arrow was a suspect for random exits after eat+move.
(define (game-on-move!)
  (set! *last-act* "move")
  #t)
